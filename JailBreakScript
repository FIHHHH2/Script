        game:GetService("SoundService"),
        game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui"),
        game:GetService("Lighting"),
        game:GetService("ReplicatedStorage")
    }
    local function applyVolumeToSound(sound)
        if not sound:IsA("Sound") then return end
        
        -- Store original volume if not already stored
        if not soundOrigVolumes[sound] then
            soundOrigVolumes[sound] = sound.Volume
            
            -- Listen for Volume changes by the game scripts
            sound:GetPropertyChangedSignal("Volume"):Connect(function()
                local expectedVolume = soundOrigVolumes[sound] * audioVolumeMultiplier
                if math.abs(sound.Volume - expectedVolume) > 0.01 then
                    soundOrigVolumes[sound] = sound.Volume
                    sound.Volume = sound.Volume * audioVolumeMultiplier
                end
            end)
        end
        
        sound.Volume = soundOrigVolumes[sound] * audioVolumeMultiplier
    end
    -- Apply to all existing sounds
    for _, service in ipairs(safeServices) do
        for _, desc in ipairs(service:GetDescendants()) do
            pcall(applyVolumeToSound, desc)
        end
    end
    -- Listen for new sounds
    for _, service in ipairs(safeServices) do
        service.DescendantAdded:Connect(function(desc)
            pcall(applyVolumeToSound, desc)
        end)
    end
end

local function updateESP()
    if not espEnabled then
        clearAllESP()
        return
    end
    local bounties = getBounties()
    local localChar = LocalPlayer.Character
    local localHrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local highlight = espFolder:FindFirstChild(player.Name .. "_Highlight")
            local billboard = espFolder:FindFirstChild(player.Name .. "_Billboard")
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                if not highlight or not billboard then
                    setupCharacter(player, player.Character)
                    highlight = espFolder:FindFirstChild(player.Name .. "_Highlight")
                    billboard = espFolder:FindFirstChild(player.Name .. "_Billboard")
                end
            end
            if highlight then
                highlight.Enabled = espShowHighlight
                highlight.FillTransparency = espHighlightFillTransparency
                highlight.OutlineTransparency = espHighlightOutlineTransparency
                local bounty = bounties[player.Name] or 0
                local color = getBountyColor(bounty)
                highlight.FillColor = color
                highlight.OutlineColor = color
            end
            if billboard then
                billboard.Enabled = espShowNames or espShowDistance or espShowBounty
                local label = billboard:FindFirstChild("Label")
                if label then
                    local bounty = bounties[player.Name] or 0
                    local color = getBountyColor(bounty)
                    label.TextColor3 = color
                    local nameStr = espShowNames and player.Name or ""
                    local distStr = ""
                    if espShowDistance and localHrp and player.Character then
                        local targetHrp = player.Character:FindFirstChild("HumanoidRootPart")
                        if targetHrp then
                            local distance = math.floor((localHrp.Position - targetHrp.Position).Magnitude)
                            distStr = string.format(" [%d studs]", distance)
                        end
                    end
                    local bountyStr = ""
                    if espShowBounty and bounty > 0 then
                        bountyStr = string.format("\nBounty: $%d", bounty)
                    end
                    label.Text = nameStr .. distStr .. bountyStr
                end
            end
        end
    end
end

local function updateInfiniteAmmo()
    if not weaponModifiers.infiniteAmmo then return end
    pcall(function()
        local InventoryItemUtils = require(ReplicatedStorage:FindFirstChild("Inventory", true):FindFirstChild("InventoryItemUtils"))
        local ItemDataUtils = require(ReplicatedStorage:FindFirstChild("App", true):FindFirstChild("ItemDataUtils"))
        local char = LocalPlayer.Character
        if not char then return end
        -- Find the equipped tool's inventory item value
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") then
                local invValue = tool:FindFirstChild("InventoryItemValue") or tool:FindFirstChild("inventoryItemValue")
                if invValue then
                    local ammoCurrent = invValue:GetAttribute("AmmoCurrentLocal")
                    local ammoServer = invValue:GetAttribute("AmmoCurrent")
                    if ammoCurrent ~= nil then
                        -- Get the weapon's MagSize from config
                        local itemName = invValue:GetAttribute("Name") or tool.Name
                        local magSize = nil
                        pcall(function()
                            local cfg = ItemDataUtils.getConfig(itemName)
                            if cfg then magSize = cfg.MagSize end
                        end)
                        if not magSize then
                            local ItemConfig = ReplicatedStorage:FindFirstChild("ItemConfig", true)
                            if ItemConfig then
                                local cfgMod = ItemConfig:FindFirstChild(tool.Name)
                                if cfgMod then
                                    local ok, cfg = pcall(require, cfgMod)
                                    if ok and cfg.MagSize then magSize = cfg.MagSize end
                                end
                            end
                        end
                        magSize = magSize or 30
                        -- Keep ammo at max so we never need to reload
                        if ammoCurrent < magSize then
                            invValue:SetAttribute("AmmoCurrentLocal", magSize)
                            invValue:SetAttribute("AmmoCurrent", magSize)
                        end
                    end
                end
            end
        end
    end)
end

local function updateVehicle()
    local VehicleUtilsObj = ReplicatedStorage:FindFirstChild("VehicleUtils", true)
    if not VehicleUtilsObj then return end
    pcall(function()
        local VehicleUtils = require(VehicleUtilsObj)
        -- Keep local nitroState attributes at max
        if infiniteBoostEnabled and VehicleUtils.nitroState then
            pcall(function()
                VehicleUtils.nitroState.Nitro = 250
                VehicleUtils.nitroState.NitroLastMax = 250
                VehicleUtils.nitroState.NitroForceUIUpdate = true
            end)
        end
        local packet = VehicleUtils.GetLocalVehiclePacket()
        if packet then
            if not packet._origHeight then
                packet._origHeight = packet.Height or 3
                packet._origSuspension = packet.Suspension or 4
                packet._origTurnSpeed = packet.TurnSpeed or 1.4
            end
            
            -- Detect vehicle type from packet (reliable for all vehicles)
            local isMotorcycle = (packet.Type == "Motorcycle")
            
            if isMotorcycle then
                -- Motorcycle settings
                if bikeSpeedMult > 1.0 then
                    packet.EngineSpeedMult = bikeSpeedMult
                else
                    packet.EngineSpeedMult = nil
                end
                packet.TurnSpeed = packet._origTurnSpeed * bikeTurnSpeedMult
            else
                -- Car settings
                if carSpeedMult > 1.0 then
                    packet.EngineSpeedMult = carSpeedMult
                else
                    packet.EngineSpeedMult = nil
                end
                packet.TurnSpeed = packet._origTurnSpeed * carTurnSpeedMult
            end
            
            -- Apply plane thrust multiplier to active plane CONST (per-frame)
            if _activePlaneConst and _activePlaneOrigThrust then
                _activePlaneConst.MAX_THRUST = _activePlaneOrigThrust * jetSpeedMult
            end
            
            packet.Height = packet._origHeight + carHeightOffset
            -- Keep local packet custom state fields locked to bypass depletion
            if infiniteBoostEnabled then
                packet.Nitro = true
                packet.Nitrof1 = true
                packet.NitroLoop = true
                
                -- Support Volt bike/chassis boost
                if packet.Model then
                    packet.Model:SetAttribute("Nitro", 250)
                end
            end
        end
    end)
end
-- Hook boat/jetski/heli/plane/volt systems
local function hookVehicles()
    -- 1. Hook Boat class
    pcall(function()
        local BoatModObj = ReplicatedStorage:FindFirstChild("Game", true)
        local BoatMod = BoatModObj and BoatModObj:FindFirstChild("Boat") and BoatModObj.Boat:FindFirstChild("Boat")
        if BoatMod then
            local Boat = require(BoatMod)
            local origBoatUpdatePhysics = Boat.UpdatePhysics
            Boat.UpdatePhysics = function(self)
                local p1 = self
                local v1 = p1:GetAreTiresPopped()
                local BuoyancySensor = p1.BuoyancySensor
                if not BuoyancySensor then
                    local BuoyancySensor2 = Instance.new("BuoyancySensor")
                    BuoyancySensor2.Parent = p1.PartBase
                    p1.BuoyancySensor = BuoyancySensor2
                    p1.maid.sensor = BuoyancySensor2
                    BuoyancySensor = BuoyancySensor2
                end
                local TouchingSurface = BuoyancySensor.TouchingSurface
                
                -- Drive on land forces AlignOrientation to be enabled
                p1.AlignOrientation.Enabled = TouchingSurface or boatDriveOnLand
                local v2 = p1.PartBase.CFrame
                local v3 = v2:VectorToObjectSpace(p1.PartBase.Velocity)
                local v6 = Vector3.new(0, 0, -p1.SpringAccelp * (if p1.SpringAccelp > 0 then p1.Config.SpeedForward else p1.Config.SpeedForward * 0.5))
                if v1 then
                    v6 = v6 * 0.05
                end
                -- Boat speed multiplier + land friction bypass
                if not TouchingSurface then
                    if boatDriveOnLand then
                        v6 = v6 * boatSpeedMult
                    else
                        v6 = v6 * 0.25 * boatSpeedMult
                    end
                else
                    v6 = v6 * boatSpeedMult
                end
                p1.Force.Force = v6 * p1.PartBase.AssemblyMass * 10 + -Vector3.new(v3.X * 3, 0, v3.Z * (p1.Config.FrictionFwd or 0.05) + v3.Z * math.abs(v3.Z) * 0.001) * p1.PartBase.AssemblyMass
                local v13 = math.clamp(-v2:VectorToObjectSpace(p1.PartBase.RotVelocity).Y / 0.5, -1, 1)
                local v15 = math.clamp(-v3.z / 80, -1, 1) * 0.8 + p1.SpringAccelp * 0.2
                local v24 = math.clamp(1 - (p1.Config.TurnCurveCoeff or 1) * math.sqrt((math.clamp((math.abs(-v3.Z) - 100) / 800, 0, 1))), 0.05, 1) * (p1.SpringHeadingp * math.pi * p1.Config.MaximumTurnAngle) * 0.25
                local v25 = CFrame.new
                p1.AlignOrientation.CFrame = v25(Vector3.new(0, 0, 0), Vector3.new(v2.LookVector.X, 0, v2.LookVector.Z).Unit) * CFrame.Angles(0, 0, (v13 + p1.SwayY) * math.pi * 0.03) * CFrame.Angles((v15 + p1.SwayX) * math.pi * 0.02, 0, 0) * CFrame.Angles(0, v24, 0) + v2.p
            end
        end
    end)
    -- 2. Hook JetSki class
    pcall(function()
        local JetSkiObj = ReplicatedStorage:FindFirstChild("Game", true)
        local JetSkiMod = JetSkiObj and JetSkiObj:FindFirstChild("VehicleSystem") and JetSkiObj.VehicleSystem:FindFirstChild("JetSki")
        if JetSkiMod then
            local JetSki = require(JetSkiMod)
            local origJetSkiFromPacket = JetSki.FromPacket
            JetSki.FromPacket = function(p1)
                local obj = origJetSkiFromPacket(p1)
                if obj and obj.VectorForce then
                    local originalVectorForce = obj.VectorForce
                    local proxyForce = {}
                    setmetatable(proxyForce, {
                        __newindex = function(tbl, key, val)
                            if key == "Force" then
                                local touching = obj.BuoyancySensor and obj.BuoyancySensor.TouchingSurface
                                local force = val
                                if not touching then
                                    if boatDriveOnLand then
                                        force = force * (1 / 0.3) * boatSpeedMult
                                    else
                                        force = force * boatSpeedMult
                                    end
                                else
                                    force = force * boatSpeedMult
                                end
                                originalVectorForce.Force = force
                            else
                                originalVectorForce[key] = val
                            end
                        end,
                        __index = function(tbl, key)
                            if key == "Force" then
                                return originalVectorForce.Force
                            end
                            return originalVectorForce[key]
                        end
                    })
                    obj.VectorForce = proxyForce
                end
                return obj
            end
        end
    end)
    -- 3. Hook Heli class (Helicopters, Drones, UFOs, etc.)
    pcall(function()
        local HeliMod = ReplicatedStorage:FindFirstChild("Game", true):FindFirstChild("Vehicle"):FindFirstChild("Heli")
        if HeliMod then
            local Heli = require(HeliMod)
            local origHeliUpdate = Heli.Update
            Heli.Update = function(self, p31)
                self.SpeedMult = heliSpeedMult
                self.ForwardMult = heliForwardMult
                self.UpMult = heliUpMult
                return origHeliUpdate(self, p31)
            end
        end
    end)
    -- 4. Hook Plane class (Jet, Stunt) — capture CONST for per-frame thrust modification
    pcall(function()
        local PlaneMod = ReplicatedStorage:FindFirstChild("Game", true):FindFirstChild("Plane"):FindFirstChild("BaseUserControlledPlane")
        if PlaneMod then
            local Plane = require(PlaneMod)
            local origPlaneNew = Plane.new
            Plane.new = function(...)
                local self = origPlaneNew(...)
                if self and self.CONST then
                    -- Store reference so updateVehicle can modify thrust per-frame
                    _activePlaneConst = self.CONST
                    _activePlaneOrigThrust = self.CONST.MAX_THRUST or 700
                end
                return self
            end
        end
    end)
    -- 4b. Also hook Jet module to capture its plane CONST (Jet wraps BaseUserControlledPlane)
    pcall(function()
        local JetMod = ReplicatedStorage:FindFirstChild("Game", true):FindFirstChild("Plane"):FindFirstChild("Jet")
        if JetMod then
            local Jet = require(JetMod)
            local origJetNew = Jet.new
            Jet.new = function(...)
                local self = origJetNew(...)
                if self and self.Plane and self.Plane.CONST then
                    _activePlaneConst = self.Plane.CONST
                    _activePlaneOrigThrust = self.Plane.CONST.MAX_THRUST or 1400
                end
                return self
            end
        end
    end)
    -- 4c. Hook Stunt plane module (wraps BaseUserControlledPlane like Jet)
    pcall(function()
        local StuntMod = ReplicatedStorage:FindFirstChild("Game", true):FindFirstChild("Plane")
        StuntMod = StuntMod and StuntMod:FindFirstChild("Stunt")
        if StuntMod then
            local Stunt = require(StuntMod)
            local origStuntNew = Stunt.new
            Stunt.new = function(...)
                local self = origStuntNew(...)
                if self and self.Plane and self.Plane.CONST then
                    _activePlaneConst = self.Plane.CONST
                    _activePlaneOrigThrust = self.Plane.CONST.MAX_THRUST or 790
                end
                return self
            end
        end
    end)
    -- 5. Hook Volt bike class
    pcall(function()
        local VoltMod = ReplicatedStorage:FindFirstChild("Game", true):FindFirstChild("Vehicle"):FindFirstChild("Volt")
        if VoltMod then
            local Volt = require(VoltMod)
            local origVoltUpdate = Volt.Update
            Volt.Update = function(self)
                origVoltUpdate(self)
                if voltSpeedMult > 1.0 then
                    local engine = self.Model and self.Model:FindFirstChild("Engine")
                    local throttle = self.Throttle or 0
                    if engine and self.Force and math.abs(throttle) > 0.05 then
                        local extraForce = engine.CFrame.LookVector * throttle * engine.AssemblyMass * 145 * (voltSpeedMult - 1.0)
                        self.Force.Force = self.Force.Force + extraForce
                    end
                end
            end
        end
    end)
end
-- Car Flight Control
local flyBV = nil
local flyBG = nil
local function updateCarFlight()
    local VehicleUtilsObj = ReplicatedStorage:FindFirstChild("VehicleUtils", true)
    if not VehicleUtilsObj then return end
    
    local VehicleUtils = require(VehicleUtilsObj)
    local packet = VehicleUtils.GetLocalVehiclePacket()
    
    if not carFlightEnabled or not packet or not packet.Model then
        if flyBV then flyBV:Destroy() flyBV = nil end
        if flyBG then flyBG:Destroy() flyBG = nil end
        return
    end
    
    local base = packet.Base or (packet.Model and packet.Model.PrimaryPart) or (packet.Model and packet.Model:FindFirstChild("Engine")) or (packet.Model and packet.Model:FindFirstChildOfClass("BasePart"))
    if not base then
        if flyBV then flyBV:Destroy() flyBV = nil end
        if flyBG then flyBG:Destroy() flyBG = nil end
        return
    end
    
    if not flyBV or flyBV.Parent ~= base then
        if flyBV then flyBV:Destroy() end
        flyBV = Instance.new("BodyVelocity")
        flyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        flyBV.Velocity = Vector3.new(0, 0, 0)
        flyBV.Parent = base
    end
    
    if not flyBG or flyBG.Parent ~= base then
        if flyBG then flyBG:Destroy() end
        flyBG = Instance.new("BodyGyro")
        flyBG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        flyBG.CFrame = base.CFrame
        flyBG.Parent = base
    end
    
    local camera = workspace.CurrentCamera
    local moveDir = Vector3.new(0, 0, 0)
    
    local isPressed = function(key)
        return UserInputService:IsKeyDown(key)
    end
    
    if isPressed(Enum.KeyCode.W) then
        moveDir = moveDir + camera.CFrame.LookVector
    end
    if isPressed(Enum.KeyCode.S) then
        moveDir = moveDir - camera.CFrame.LookVector
    end
    if isPressed(Enum.KeyCode.A) then
        moveDir = moveDir - camera.CFrame.RightVector
    end
    if isPressed(Enum.KeyCode.D) then
        moveDir = moveDir + camera.CFrame.RightVector
    end
    if isPressed(Enum.KeyCode.Space) then
        moveDir = moveDir + Vector3.new(0, 1, 0)
    end
    if isPressed(Enum.KeyCode.LeftShift) or isPressed(Enum.KeyCode.LeftControl) then
        moveDir = moveDir - Vector3.new(0, 1, 0)
    end
    
    if moveDir.Magnitude > 0 then
        moveDir = moveDir.Unit
        flyBV.Velocity = moveDir * carFlightSpeed
    else
        flyBV.Velocity = Vector3.new(0, 0, 0)
    end
    
    local look = camera.CFrame.LookVector
    local flatLook = Vector3.new(look.X, 0, look.Z).Unit
    if flatLook.Magnitude > 0 then
        flyBG.CFrame = CFrame.new(Vector3.new(), flatLook)
    end
end

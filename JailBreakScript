local function isLootPrompt(specName, partName)
    if not specName then return false end
    local nameLower = string.lower(specName)
    local partLower = partName and string.lower(partName) or ""
    
    -- Explicitly exclude generic or non-robbery prompts
    if string.find(nameLower, "sit") or string.find(nameLower, "enter") or 
       string.find(nameLower, "passenger") or string.find(nameLower, "driver") or 
       string.find(nameLower, "spawn") or string.find(nameLower, "drawer") or 
       string.find(nameLower, "elevator") or string.find(nameLower, "door") or
       string.find(nameLower, "hatch") or string.find(nameLower, "rope") or
       string.find(nameLower, "lever") or string.find(nameLower, "switch") or
       string.find(nameLower, "talk") or string.find(nameLower, "lantern") or
       string.find(nameLower, "atm") or string.find(partLower, "atm") then
        return false
    end
    
    local lootKeywords = {
        "jewel", "bone", "mask", "egg", "arm", "picture", "relic", "mummy",
        "gold", "treasure", "briefcase", "cash", "money", "crate", "grab", "steal",
        "register", "cashier", "vault"
    }
    
    for _, kw in ipairs(lootKeywords) do
        if string.find(nameLower, kw) or string.find(partLower, kw) then
            return true
        end
    end
    return false
end

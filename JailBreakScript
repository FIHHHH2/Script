local function tweenToPos(targetPos, speed)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    
    local startPos = hrp.Position
    local horizontalDist = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(startPos.X, 0, startPos.Z)).Magnitude
    
    -- Parameters
    local groundStepSize = 3
    local groundStepDelay = 0.06 -- ~50 studs/sec
    
    local skyStepSize = 9
    local skyStepDelay = 0.06 -- ~150 studs/sec
    
    -- Helper to check if under ceiling
    local function underCeiling(pos)
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        raycastParams.FilterDescendantsInstances = {char}
        local result = workspace:Raycast(pos, Vector3.new(0, 150, 0), raycastParams)
        return result ~= nil
    end
    if horizontalDist <= 150 then
        -- Short distance: Tween directly on ground/noclip
        local steps = math.ceil(horizontalDist / groundStepSize)
        for i = 1, steps do
            if not actualAutoRobEnabled then break end
            pcall(function()
                hrp.Velocity = Vector3.new(0, 0, 0)
                hrp.RotVelocity = Vector3.new(0, 0, 0)
            end)
            local currentTarget = startPos:Lerp(targetPos, i / steps)
            hrp.CFrame = CFrame.new(currentTarget)
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end) end
            task.wait(groundStepDelay)
        end
    else
        -- Long distance: Sky travel
        -- 1. Exit building horizontally first if under a ceiling
        local currentPos = startPos
        local exitSteps = 0
        local maxExitSteps = 100 -- Prevent infinite loops
        
        while underCeiling(currentPos) and exitSteps < maxExitSteps do
            if not actualAutoRobEnabled then break end
            exitSteps = exitSteps + 1
            
            -- Move horizontally towards target X, Z
            local remainingHoriz = Vector3.new(targetPos.X - currentPos.X, 0, targetPos.Z - currentPos.Z)
            local dir = remainingHoriz.Unit
            local dist = remainingHoriz.Magnitude
            
            local moveDist = math.min(groundStepSize, dist)
            if dist < 0.1 then break end
            
            currentPos = currentPos + dir * moveDist
            pcall(function()
                hrp.Velocity = Vector3.new(0, 0, 0)
                hrp.RotVelocity = Vector3.new(0, 0, 0)
            end)
            hrp.CFrame = CFrame.new(currentPos)
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end) end
            task.wait(groundStepDelay)
        end
        
        if not actualAutoRobEnabled then return end
        
        -- 2. Now we are in open sky (or reached target/max steps). Rise vertically.
        local safeY = math.max(currentPos.Y + 130, targetPos.Y + 130)
        safeY = math.clamp(safeY, -50, 380)
        
        local upPos = Vector3.new(currentPos.X, safeY, currentPos.Z)
        local distUp = (upPos - currentPos).Magnitude
        local stepsUp = math.ceil(distUp / skyStepSize)
        
        for i = 1, stepsUp do
            if not actualAutoRobEnabled then break end
            pcall(function()
                hrp.Velocity = Vector3.new(0, 0, 0)
                hrp.RotVelocity = Vector3.new(0, 0, 0)
            end)
            hrp.CFrame = CFrame.new(currentPos:Lerp(upPos, i / stepsUp))
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end) end
            task.wait(skyStepDelay)
        end
        
        if not actualAutoRobEnabled then return end
        
        -- 3. Move horizontally in the sky
        local skyStart = upPos
        local skyEnd = Vector3.new(targetPos.X, safeY, targetPos.Z)
        local distHoriz = (skyEnd - skyStart).Magnitude
        local stepsHoriz = math.ceil(distHoriz / skyStepSize)
        
        for i = 1, stepsHoriz do
            if not actualAutoRobEnabled then break end
            pcall(function()
                hrp.Velocity = Vector3.new(0, 0, 0)
                hrp.RotVelocity = Vector3.new(0, 0, 0)
            end)
            hrp.CFrame = CFrame.new(skyStart:Lerp(skyEnd, i / stepsHoriz))
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end) end
            task.wait(skyStepDelay)
        end
        
        if not actualAutoRobEnabled then return end
        
        -- 4. Descend vertically down onto target
        local downStart = skyEnd
        local downEnd = targetPos
        local distDown = (downEnd - downStart).Magnitude
        local stepsDown = math.ceil(distDown / skyStepSize)
        
        for i = 1, stepsDown do
            if not actualAutoRobEnabled then break end
            pcall(function()
                hrp.Velocity = Vector3.new(0, 0, 0)
                hrp.RotVelocity = Vector3.new(0, 0, 0)
            end)
            hrp.CFrame = CFrame.new(downStart:Lerp(downEnd, i / stepsDown))
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end) end
            task.wait(skyStepDelay)
        end
    end
    
    -- Final stabilization and reset state
    pcall(function()
        hrp.Velocity = Vector3.new(0, 0, 0)
        hrp.RotVelocity = Vector3.new(0, 0, 0)
        if humanoid then
            humanoid:ChangeState(Enum.HumanoidStateType.Running)
        end
    end)
end

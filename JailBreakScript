local _lastAutoAssistTick = 0
local _assistHoldStartTime = nil
local ASSIST_ACTION_KEYWORDS = {
    "collect", "rob", "dynamite", "lever", "hack", "open", "vault",
    "safe", "bag", "keycard", "crack", "drill", "grab", "steal",
    "break", "smash", "switch", "sit", "rope", "hatch",
    "inspect", "pick", "enter"
}
local function isAssistAction(name)
    if not name then return false end
    local lower = string.lower(name)
    for _, keyword in ipairs(ASSIST_ACTION_KEYWORDS) do
        if string.find(lower, keyword) then
            return true
        end
    end
    return false
end
local function doAutoAssistRobbery()
    if not autoAssistRobberyEnabled then
        _assistHoldStartTime = nil
        return
    end
    local UIModule = getUIModule()
    if not UIModule then return end
    local CircleAction = UIModule.CircleAction
    if not CircleAction then return end
    local spec = CircleAction.Spec
    if not spec then
        _assistHoldStartTime = nil
        return
    end
    if spec.Enabled == false then
        _assistHoldStartTime = nil
        return
    end
    if not spec.Callback then
        _assistHoldStartTime = nil
        return
    end
    local shouldAssist = isAssistAction(spec.Name)
    if not shouldAssist and spec.Timed and not spec.Name then
        shouldAssist = true
    end
    if not shouldAssist then
        _assistHoldStartTime = nil
        return
    end
    if spec.Timed then
        if not spec.Pressed then
            CircleAction.Press()
            _assistHoldStartTime = tick()
        end
    else
        if tick() - _lastAutoAssistTick > 1.0 then
            CircleAction.Press()
            _lastAutoAssistTick = tick()
        end
    end
end

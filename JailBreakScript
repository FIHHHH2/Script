local function backupWeaponConfigs()
    local ItemConfig = ReplicatedStorage:FindFirstChild("ItemConfig", true)
    if not ItemConfig then return end
    for _, child in ipairs(ItemConfig:GetChildren()) do
        if child:IsA("ModuleScript") then
            local success, config = pcall(require, child)
            if success and type(config) == "table" then
                weaponConfigBackup[child.Name] = {
                    FireFreq = config.FireFreq,
                    MagSize = config.MagSize,
                    ReloadTime = config.ReloadTime,
                    BulletSpread = config.BulletSpread,
                    CamShakeMagnitude = config.CamShakeMagnitude,
                    FireAuto = config.FireAuto,
                    BulletSpeed = config.BulletSpeed
                }
            end
        end
    end
end
local function applyWeaponModifiers()
    local ItemConfig = ReplicatedStorage:FindFirstChild("ItemConfig", true)
    if not ItemConfig then return end
    for _, child in ipairs(ItemConfig:GetChildren()) do
        if child:IsA("ModuleScript") then
            local success, config = pcall(require, child)
            if success and type(config) == "table" then
                local backup = weaponConfigBackup[child.Name]
                if backup then
                    if backup.FireFreq ~= nil then
                        -- Use 2x original rate to stay within server validation
                        config.FireFreq = weaponModifiers.fastFire and (backup.FireFreq * 2) or backup.FireFreq
                    end
                    -- MagSize is no longer modified here; infinite ammo is handled
                    -- by resetting AmmoCurrentLocal in the heartbeat loop
                    if backup.ReloadTime ~= nil then
                        config.ReloadTime = weaponModifiers.instaReload and 0.1 or backup.ReloadTime
                    end
                    if backup.BulletSpread ~= nil then
                        config.BulletSpread = weaponModifiers.noSpread and 0 or backup.BulletSpread
                    end
                    if backup.CamShakeMagnitude ~= nil then
                        config.CamShakeMagnitude = weaponModifiers.noRecoil and 0 or backup.CamShakeMagnitude
                    end
                    if backup.FireAuto ~= nil then
                        config.FireAuto = weaponModifiers.autoFire and true or backup.FireAuto
                    end
                    if backup.BulletSpeed ~= nil then
                        config.BulletSpeed = weaponModifiers.fastBullets and 10000 or backup.BulletSpeed
                    end
                end
            end
        end
    end
end
local function restoreWeaponConfigs()
    local ItemConfig = ReplicatedStorage:FindFirstChild("ItemConfig", true)
    if not ItemConfig then return end
    for _, child in ipairs(ItemConfig:GetChildren()) do
        if child:IsA("ModuleScript") then
            local success, config = pcall(require, child)
            if success and type(config) == "table" then
                local backup = weaponConfigBackup[child.Name]
                if backup then
                    for k, v in pairs(backup) do
                        config[k] = v
                    end
                end
            end
        end
    end
end

-- ===================== ESP =====================
local espFolder = Instance.new("Folder")
espFolder.Name = ESP_FOLDER_NAME
espFolder.Parent = CoreGui

local function getBountyColor(bounty)
    if bounty <= 0 then
        return Color3.fromRGB(0, 255, 127)
    elseif bounty < 2000 then
        return Color3.fromRGB(255, 215, 0)
    elseif bounty < 5000 then
        return Color3.fromRGB(255, 127, 0)
    else
        return Color3.fromRGB(255, 0, 80)
    end
end

local function getBounties()
    local bounties = {}
    local bountyDataObj = ReplicatedStorage:FindFirstChild("BountyData")
    if bountyDataObj then
        local success, data = pcall(function()
            return HttpService:JSONDecode(bountyDataObj.Value)
        end)
        if success and type(data) == "table" then
            for _, item in ipairs(data) do
                if item.Name and item.Bounty then
                    bounties[item.Name] = item.Bounty
                end
            end
        end
    end
    return bounties
end

local function setupCharacter(player, char)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end

    local highlight = espFolder:FindFirstChild(player.Name .. "_Highlight")
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = player.Name .. "_Highlight"
        highlight.FillTransparency = 0.25
        highlight.OutlineTransparency = 0.2
        highlight.Parent = espFolder
    end
    highlight.Adornee = char

    local billboard = espFolder:FindFirstChild(player.Name .. "_Billboard")
    if not billboard then
        billboard = Instance.new("BillboardGui")
        billboard.Name = player.Name .. "_Billboard"
        billboard.AlwaysOnTop = true
        billboard.Size = UDim2.new(0, 200, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.Parent = espFolder

        local label = Instance.new("TextLabel")
        label.Name = "Label"
        label.BackgroundTransparency = 1
        label.Size = UDim2.new(1, 0, 1, 0)
        label.Font = Enum.Font.GothamBold
        label.TextSize = 14
        label.TextStrokeTransparency = 0
        label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        label.Parent = billboard
    end
    billboard.Adornee = hrp
end

local function createESP(player)
    if player == LocalPlayer then return end
    if player.Character then
        task.spawn(setupCharacter, player, player.Character)
    end
    local conn = player.CharacterAdded:Connect(function(char)
        task.spawn(setupCharacter, player, char)
    end)
    addConnection(conn)
end

local function removeESP(player)
    local highlight = espFolder:FindFirstChild(player.Name .. "_Highlight")
    if highlight then highlight:Destroy() end
    local billboard = espFolder:FindFirstChild(player.Name .. "_Billboard")
    if billboard then billboard:Destroy() end
end

local function clearAllESP()
    espFolder:ClearAllChildren()
end

local function updateESP()
    if not espEnabled then
        clearAllESP()
        return
    end

    local bounties = getBounties()
    local localChar = LocalPlayer.Character
    local localHrp = localChar and localChar:FindFirstChild("HumanoidRootPart")

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local highlight = espFolder:FindFirstChild(player.Name .. "_Highlight")
            local billboard = espFolder:FindFirstChild(player.Name .. "_Billboard")

            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                if not highlight or not billboard then
                    setupCharacter(player, player.Character)
                    highlight = espFolder:FindFirstChild(player.Name .. "_Highlight")
                    billboard = espFolder:FindFirstChild(player.Name .. "_Billboard")
                end
            end

            if highlight then
                highlight.Enabled = true
                local bounty = bounties[player.Name] or 0
                local color = getBountyColor(bounty)
                highlight.FillColor = color
                highlight.OutlineColor = color
            end

            if billboard then
                billboard.Enabled = true
                local label = billboard:FindFirstChild("Label")
                if label then
                    local bounty = bounties[player.Name] or 0
                    local color = getBountyColor(bounty)
                    label.TextColor3 = color

                    local distStr = ""
                    if localHrp and player.Character then
                        local targetHrp = player.Character:FindFirstChild("HumanoidRootPart")
                        if targetHrp then
                            local distance = math.floor((localHrp.Position - targetHrp.Position).Magnitude)
                            distStr = string.format(" [%d studs]", distance)
                        end
                    end

                    if bounty > 0 then
                        label.Text = string.format("%s%s\nBounty: $%d", player.Name, distStr, bounty)
                    else
                        label.Text = player.Name .. distStr
                    end
                end
            end
        end
    end
end

-- ===================== INFINITE JUMP =====================

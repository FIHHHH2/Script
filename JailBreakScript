-- ===================== PLAYER MOVEMENT UPDATE =====================
local function updatePlayerMovement()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local CharacterUtil = ReplicatedStorage:FindFirstChild("CharacterUtil", true)
        local isCrawling = false
        if CharacterUtil then
            pcall(function()
                isCrawling = require(CharacterUtil).IsCrawling
            end)
        end

        if not isCrawling then
            if noSlowEnabled then
                if humanoid.WalkSpeed < customWalkSpeed then
                    humanoid.WalkSpeed = customWalkSpeed
                end
            elseif customWalkSpeed > 16 then
                humanoid.WalkSpeed = customWalkSpeed
            end
        end
    end
end

-- ===================== VEHICLE =====================
local function updateVehicle()
    local VehicleUtilsObj = ReplicatedStorage:FindFirstChild("VehicleUtils", true)
    if not VehicleUtilsObj then return end
    pcall(function()
        local VehicleUtils = require(VehicleUtilsObj)
        local packet = VehicleUtils.GetLocalVehiclePacket()
        if packet then
            if not packet._origHeight then
                packet._origHeight = packet.Height or 3
                packet._origSuspension = packet.Suspension or 4
                packet._origTurnSpeed = packet.TurnSpeed or 1.4
            end
            if carSpeedMult > 1.0 then
                packet.EngineSpeedMult = carSpeedMult
            else
                packet.EngineSpeedMult = nil
            end
            packet.Height = packet._origHeight + carHeightOffset
            packet.TurnSpeed = packet._origTurnSpeed * carTurnSpeedMult
        end
    end)
end

-- ===================== AIMBOT =====================
local function isPlayerArrested(player)
    if player.Team and player.Team.Name == "Prisoner" then return true end
    local char = player.Character
    if char then
        if char:FindFirstChild("Cuffed") then return true end
        if char:FindFirstChild("Handcuffs") then return true end
        if char:GetAttribute("HasHandcuffs") then return true end
    end
    return false
end

local function isTeammate(player)
    if not LocalPlayer.Team or not player.Team then return false end
    return LocalPlayer.Team == player.Team
end

local function isAlive(player)
    local char = player.Character
    if not char then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    return humanoid.Health > 0
end

local function isVisible(targetPart)
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude

    local ignoreList = {}
    if LocalPlayer.Character then
        table.insert(ignoreList, LocalPlayer.Character)
    end
    local vehiclesFolder = workspace:FindFirstChild("Vehicles")
    if vehiclesFolder then
        table.insert(ignoreList, vehiclesFolder)
    end
    rayParams.FilterDescendantsInstances = ignoreList

    local result = workspace:Raycast(origin, direction, rayParams)
    if result then
        local hitPart = result.Instance
        local hitChar = hitPart:FindFirstAncestorOfClass("Model")
        if hitChar and hitChar == targetPart:FindFirstAncestorOfClass("Model") then
            return true
        end
        return false
    end
    return true
end

local function getClosestTarget()
    local closest = nil
    local closestDist = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if aimbotIgnoreTeam and isTeammate(player) then continue end
            if aimbotIgnoreArrested and isPlayerArrested(player) then continue end
            if not isAlive(player) then continue end

            local char = player.Character
            if not char then continue end

            local targetPart = char:FindFirstChild(aimbotTargetPart) or char:FindFirstChild("Head")
            if not targetPart then continue end

            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if not onScreen then continue end

            local screenPosV2 = Vector2.new(screenPos.X, screenPos.Y)
            local distFromCenter = (screenPosV2 - screenCenter).Magnitude

            if distFromCenter > aimbotFOV then continue end
            if aimbotIgnoreWalls and not isVisible(targetPart) then continue end

            if distFromCenter < closestDist then
                closestDist = distFromCenter
                closest = player
            end
        end
    end

    return closest
end

local function updateAimbot()
    if fovCircle then
        fovCircle.Visible = aimbotEnabled and aimbotShowFOV
        fovCircle.Radius = aimbotFOV
        fovCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    end

    if not aimbotEnabled then
        aimbotCurrentTarget = nil
        return
    end

    local isAiming = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    if not isAiming then
        aimbotCurrentTarget = nil
        return
    end

    local target = getClosestTarget()
    aimbotCurrentTarget = target

    if target and target.Character then
        local targetPart = target.Character:FindFirstChild(aimbotTargetPart) or target.Character:FindFirstChild("Head")
        if targetPart then
            local targetPos = targetPart.Position
            local currentCF = Camera.CFrame
            local targetCF = CFrame.lookAt(currentCF.Position, targetPos)

            local smoothFactor = 1 / math.clamp(aimbotSmoothing, 1, 20)
            Camera.CFrame = currentCF:Lerp(targetCF, smoothFactor)
        end
    end
end

-- ===================== WEAPON MODIFIERS =====================
local function backupWeaponConfigs()
    local ItemConfig = ReplicatedStorage:FindFirstChild("ItemConfig", true)
    if not ItemConfig then return end

    for _, child in ipairs(ItemConfig:GetChildren()) do
        if child:IsA("ModuleScript") then
            local success, config = pcall(require, child)
            if success and type(config) == "table" then
                weaponConfigBackup[child.Name] = {
                    FireFreq = config.FireFreq,
                    MagSize = config.MagSize,
                    ReloadTime = config.ReloadTime,
                    BulletSpread = config.BulletSpread,
                    CamShakeMagnitude = config.CamShakeMagnitude,
                    FireAuto = config.FireAuto,
                    BulletSpeed = config.BulletSpeed
                }
            end
        end
    end
end

local function applyWeaponModifiers()
    local ItemConfig = ReplicatedStorage:FindFirstChild("ItemConfig", true)
    if not ItemConfig then return end

    for _, child in ipairs(ItemConfig:GetChildren()) do
        if child:IsA("ModuleScript") then
            local success, config = pcall(require, child)
            if success and type(config) == "table" then
                local backup = weaponConfigBackup[child.Name]
                if backup then
                    if backup.FireFreq ~= nil then
                        config.FireFreq = weaponModifiers.fastFire and 25 or backup.FireFreq
                    end
                    if backup.MagSize ~= nil then
                        config.MagSize = weaponModifiers.maxAmmo and 250 or backup.MagSize
                    end
                    if backup.ReloadTime ~= nil then
                        config.ReloadTime = weaponModifiers.instaReload and 0.1 or backup.ReloadTime
                    end
                    if backup.BulletSpread ~= nil then
                        config.BulletSpread = weaponModifiers.noSpread and 0 or backup.BulletSpread
                    end
                    if backup.CamShakeMagnitude ~= nil then
                        config.CamShakeMagnitude = weaponModifiers.noRecoil and 0 or backup.CamShakeMagnitude
                    end
                    if backup.FireAuto ~= nil then
                        config.FireAuto = weaponModifiers.autoFire and true or backup.FireAuto
                    end
                    if backup.BulletSpeed ~= nil then
                        config.BulletSpeed = weaponModifiers.fastBullets and 10000 or backup.BulletSpeed
                    end
                end
            end
        end
    end
end

local function restoreWeaponConfigs()
    local ItemConfig = ReplicatedStorage:FindFirstChild("ItemConfig", true)
    if not ItemConfig then return end

    for _, child in ipairs(ItemConfig:GetChildren()) do
        if child:IsA("ModuleScript") then
            local success, config = pcall(require, child)
            if success and type(config) == "table" then
                local backup = weaponConfigBackup[child.Name]
                if backup then
                    for k, v in pairs(backup) do
                        config[k] = v
                    end
                end
            end
        end
    end
end

-- ===================== AUTO ARREST =====================
-- Works by hooking into the CircleAction (E-prompt) system used for handcuff arrests,
-- and also by directly finding and pressing the active interaction spec.

local _lastAutoArrestTick = 0

local function doAutoArrest()
    if not autoArrestEnabled then return end
    if tick() - _lastAutoArrestTick < 0.5 then return end -- cooldown

    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Method 1: Use the CircleAction system (handles all E-prompts including arrest)
    local UIModule = getUIModule()
    if UIModule then
        local CircleAction = UIModule.CircleAction
        if CircleAction and CircleAction.Spec then
            local spec = CircleAction.Spec
            -- The CircleAction spec is already the closest valid interaction
            -- For arrests, the spec is present when handcuffs are equipped near a criminal
            if spec.Callback and spec.Enabled ~= false then
                -- If it's a timed action (hold E), simulate the full hold
                if spec.Timed then
                    CircleAction.Press()
                    _lastAutoArrestTick = tick()
                else
                    CircleAction.Press()
                    _lastAutoArrestTick = tick()
                end
                return
            end
        end
    end

    -- Method 2: Check if we have handcuffs equipped and look for nearby criminals
    -- If the ItemSystem is available, check the equipped item
    pcall(function()
        local ItemSystem = require(ReplicatedStorage:FindFirstChild("Game"):FindFirstChild("ItemSystem"):FindFirstChild("ItemSystem"))
        local equipped = ItemSystem.GetLocalEquipped()
        if equipped and equipped.__ClassName == "Handcuffs" then
            -- Handcuffs are equipped - find nearest criminal to arrest
            local handcuffsConfig = getHandcuffsConfig()
            local arrestDist = handcuffsConfig and handcuffsConfig.ArrestDistance or autoArrestRange

            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local targetHrp = player.Character:FindFirstChild("HumanoidRootPart")
                    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                    if targetHrp and humanoid and humanoid.Health > 0 then
                        local dist = (hrp.Position - targetHrp.Position).Magnitude
                        -- Check if they're a criminal (Prisoner team, no handcuffs already)
                        local isPrisoner = false
                        pcall(function()
                            local settings = getSettings()
                            if settings and player:FindFirstChild("TeamValue") then
                                isPrisoner = player.TeamValue.Value == (settings.Team and settings.Team.Prisoner or 2)
                            end
                        end)
                        if not isPrisoner and player.Team then
                            isPrisoner = player.Team.Name == "Criminal" or player.Team.Name == "Prisoner"
                        end

                        local alreadyArrested = player.Character:GetAttribute("HasHandcuffs") == true

                        if isPrisoner and not alreadyArrested and dist <= arrestDist then
                            -- Simulate the shoot/use input for handcuffs
                            if equipped.ShootBegin then
                                pcall(function() equipped:ShootBegin() end)
                            elseif equipped.InputBegan then
                                pcall(function()
                                    equipped:InputBegan({
                                        UserInputType = Enum.UserInputType.MouseButton1
                                    })
                                end)
                            end
                            _lastAutoArrestTick = tick()
                            return
                        end
                    end
                end
            end
        end
    end)
end

-- ===================== AUTO ROB =====================
-- Automatically interacts with robbery CircleAction prompts (E-hold interactions)
-- such as: Collect, Place Dynamite, Pull Lever, Hack, Open Vault, Bag, etc.

local _lastAutoRobTick = 0
local _robHoldStartTime = nil

-- Names of robbery-related CircleAction prompts
local ROB_ACTION_KEYWORDS = {
    "collect", "rob", "dynamite", "lever", "hack", "open", "vault",
    "safe", "bag", "keycard", "crack", "drill", "grab", "steal",
    "break", "smash", "switch", "sit", "rope", "hatch",
    "inspect", "pick", "enter"
}

local function isRobAction(name)
    if not name then return false end
    local lower = string.lower(name)
    for _, keyword in ipairs(ROB_ACTION_KEYWORDS) do
        if string.find(lower, keyword) then
            return true
        end
    end
    -- If it has no name but is a timed action near a robbery tagged object, still try
    return false
end

local function doAutoRob()
    if not autoRobEnabled then
        _robHoldStartTime = nil
        return
    end

    local UIModule = getUIModule()
    if not UIModule then return end
    local CircleAction = UIModule.CircleAction
    if not CircleAction then return end

    local spec = CircleAction.Spec
    if not spec then
        _robHoldStartTime = nil
        return
    end
    if spec.Enabled == false then
        _robHoldStartTime = nil
        return
    end
    if not spec.Callback then
        _robHoldStartTime = nil
        return
    end

    -- Decide if this is a rob action
    local shouldRob = isRobAction(spec.Name)
    -- Also rob if it's unnamed but timed (most robbery interactions are timed)
    if not shouldRob and spec.Timed and not spec.Name then
        shouldRob = true
    end

    if not shouldRob then
        _robHoldStartTime = nil
        return
    end

    -- For timed actions, we need to simulate holding E
    if spec.Timed then
        if not spec.Pressed then
            CircleAction.Press()
            _robHoldStartTime = tick()
        end
        -- The CircleAction system handles the hold duration internally via ProcessSpec
    else
        -- Instant action, just press
        if tick() - _lastAutoRobTick > 1.0 then
            CircleAction.Press()
            _lastAutoRobTick = tick()
        end
    end
end

-- ===================== AUTO OPEN DOORS =====================
-- Opens all Door2-system doors by setting their DoorOpen attribute.
-- Door2 doors listen for attribute changes and animate accordingly.
-- Also handles NetSync slide doors seen in the remote spy.

local _lastDoorScanTick = 0

local function openAllDoors()
    if not autoDoorsEnabled then return end
    if tick() - _lastDoorScanTick < 2.0 then return end -- scan every 2 seconds
    _lastDoorScanTick = tick()

    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local playerPos = hrp.Position

    -- Method 1: Door2 system - set DoorOpen attribute on nearby tagged doors
    pcall(function()
        local taggedDoors = CollectionService:GetTagged("Door2")
        for _, door in ipairs(taggedDoors) do
            if door:IsA("Model") and door.PrimaryPart then
                local dist = (door.PrimaryPart.Position - playerPos).Magnitude
                if dist <= 60 then -- only open doors within 60 studs
                    if door:GetAttribute("DoorOpen") ~= true then
                        door:SetAttribute("DoorOpen", true)
                    end
                end
            end
        end
    end)

    -- Method 2: Try using DoorUtils directly for more reliable door opening
    local DoorUtils = getDoorUtils()
    if DoorUtils then
        pcall(function()
            local taggedDoors = CollectionService:GetTagged("Door2")
            for _, door in ipairs(taggedDoors) do
                if door:IsA("Model") and door.PrimaryPart then
                    local dist = (door.PrimaryPart.Position - playerPos).Magnitude
                    if dist <= 60 then
                        pcall(function()
                            if DoorUtils.getOpen and not DoorUtils.getOpen(door) then
                                DoorUtils.setOpen(door, true)
                            end
                        end)
                    end
                end
            end
        end)
    end

    -- Method 3: Handle slide doors (NetSync-based doors like prison gates)
    -- These use a different system through the network event with CFrame-based animation
    pcall(function()
        -- Find SlideDoor models in workspace
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and (obj.Name == "SlideDoor" or string.find(obj.Name, "SlideDoor")) then
                if obj.PrimaryPart then
                    local dist = (obj.PrimaryPart.Position - playerPos).Magnitude
                    if dist <= 60 then
                        -- Try setting attributes that control slide doors
                        pcall(function()
                            obj:SetAttribute("DoorOpen", true)
                        end)
                    end
                end
            end
        end
    end)

    -- Method 4: Handle doors that use DoorPctOpen (percentage-based doors)
    pcall(function()
        local taggedDoors = CollectionService:GetTagged("Door2")
        for _, door in ipairs(taggedDoors) do
            if door:IsA("Model") and door.PrimaryPart then
                local dist = (door.PrimaryPart.Position - playerPos).Magnitude
                if dist <= 60 then
                    local currentPct = door:GetAttribute("DoorPctOpen")
                    if currentPct == nil or currentPct < 1 then
                        door:SetAttribute("DoorPctOpen", 1)
                    end
                end
            end
        end
    end)
end


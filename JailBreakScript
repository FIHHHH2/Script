    valLabel.TextSize = 11
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    valLabel.Parent = container
    local value = defaultValue
    local function update(pct)
        local rawValue = minVal + (maxVal - minVal) * pct
        -- Snap to step
        value = math.clamp(math.round(rawValue / step) * step, minVal, maxVal)
        
        -- Avoid precision issues with integer values
        if step >= 1 then
            value = math.round(value)
        end
        local visualPct = (value - minVal) / (maxVal - minVal)
        handle.Position = UDim2.new(visualPct, 0, 0.5, 0)
        sliderFill.Size = UDim2.new(visualPct, 0, 1, 0)
        valLabel.Text = string.format(formatStr, value)
        callback(value)
    end
    -- Initial position
    update((defaultValue - minVal) / (maxVal - minVal))
    -- Drag logic
    local dragging = false
    local function processInput(input)
        local inputX = input.Position.X
        local sliderX = sliderBg.AbsolutePosition.X
        local width = sliderBg.AbsoluteSize.X
        local pct = math.clamp((inputX - sliderX) / width, 0, 1)
        update(pct)
    end
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            processInput(input)
        end
    end)
    -- Make clicking the bar also update the slider
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            processInput(input)
            dragging = true
        end
    end)

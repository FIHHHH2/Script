local function getBountyColor(bounty)
    if bounty <= 0 then
        return Color3.fromRGB(0, 255, 127)
    elseif bounty < 2000 then
        return Color3.fromRGB(255, 215, 0)
    elseif bounty < 5000 then
        return Color3.fromRGB(255, 127, 0)
    else
        return Color3.fromRGB(255, 0, 80)
    end
end
local function getBounties()
    local bounties = {}
    local bountyDataObj = ReplicatedStorage:FindFirstChild("BountyData")
    if bountyDataObj then
        local success, data = pcall(function()
            return HttpService:JSONDecode(bountyDataObj.Value)
        end)
        if success and type(data) == "table" then
            for _, item in ipairs(data) do
                if item.Name and item.Bounty then
                    bounties[item.Name] = item.Bounty
                end
            end
        end
    end
    return bounties
end

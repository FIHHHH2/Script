		if sound:IsA("Sound") then
			if not sound:GetAttribute("OriginalVolume") then
				sound:SetAttribute("OriginalVolume", sound.Volume)
			end
			sound.Volume = sound:GetAttribute("OriginalVolume") * (val / 100)
		end
	end
end


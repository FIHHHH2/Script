end
local function getMurderer()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LP and getRole(p) == "Murderer" and not getDead(p) then
			return p
		end
	end
	return nil
end
local function killAll()
	local char = LP.Character
	local kn = char and char:FindFirstChild("Knife") or (LP.Backpack and LP.Backpack:FindFirstChild("Knife"))
	if not kn then return end
	if char and not char:FindFirstChild("Knife") then
		char:FindFirstChildOfClass("Humanoid"):EquipTool(kn)
	end
	local handle = kn:FindFirstChild("Handle")
	if handle then
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= LP then
				local root = getRoot(p)
				if root and not getDead(p) then
					firetouchinterest(handle, root, 0)
					firetouchinterest(handle, root, 1)
				end
			end
		end
	end
end
local function instantKillMurderer()
	local mud = getMurderer()
	local char = LP.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	local gun = char and char:FindFirstChild("Gun") or (LP.Backpack and LP.Backpack:FindFirstChild("Gun"))

	if mud and root and hum and gun then
		local mRoot = getRoot(mud)
		if mRoot then
			local oldCF = root.CFrame
			root.CFrame = mRoot.CFrame * CFrame.new(0, 0, 4)
			task.wait(0.1)
			if not char:FindFirstChild("Gun") then
				hum:EquipTool(gun)
			end
			task.wait(0.1)
			CAM.CFrame = CFrame.new(CAM.CFrame.Position, mRoot.Position)
			gun:Activate()
			task.wait(0.15)
			root.CFrame = oldCF
		end
	end
end
local trollWalkActive = false
local trollWalkConnection = nil
local trollWalkTrack = nil
local currentTrollTarget = nil
local function stopTrollWalk()
	trollWalkActive = false
	if trollWalkConnection then
		trollWalkConnection:Disconnect()
		trollWalkConnection = nil
	end
	if trollWalkTrack then
		trollWalkTrack:Stop()
		trollWalkTrack:Destroy()
		trollWalkTrack = nil
	end
	currentTrollTarget = nil
end
local function trollWalkOnPlayer(p)
	local char = LP.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not (char and root and hum) then return end
	local tChar = p.Character
	local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
	if not tRoot then return end
	-- Toggle off if clicking the same player again
	if trollWalkActive and currentTrollTarget == p then
		stopTrollWalk()
		return
	end
	stopTrollWalk()
	trollWalkActive = true
	currentTrollTarget = p

	-- Play walk animation fallback
	local animate = char:FindFirstChild("Animate")
	local walkTrackVal = animate and animate:FindFirstChild("walk")
	local walkAnim = walkTrackVal and walkTrackVal:FindFirstChildOfClass("Animation")
	if walkAnim then
		pcall(function()
			trollWalkTrack = hum:LoadAnimation(walkAnim)
			trollWalkTrack.Looped = true
			trollWalkTrack:Play()
		end)
	end
	-- Teleport behind player first
	root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3.5)
	-- Keep teleporting behind player with back-and-forth movement
	trollWalkConnection = RSv.RenderStepped:Connect(function()
		if not trollWalkActive or not p.Parent or not tRoot.Parent or not root.Parent then
			stopTrollWalk()
			return
		end

		-- Also stop if target player dies
		local tHum = tChar:FindFirstChildOfClass("Humanoid")
		if tHum and tHum.Health <= 0 then
			stopTrollWalk()
			return
		end

		-- Oscillate back and forth relative to the target's back (between 1.5 and 5.5 studs behind)
		local offsetZ = 3.5 + math.sin(tick() * 10) * 2
		root.CFrame = tRoot.CFrame * CFrame.new(0, 0, offsetZ)
	end)
end
local followActive = false
local followConnection = nil
local followTarget = nil
local function stopFollowPlayer()
	followActive = false
	if followConnection then
		followConnection:Disconnect()

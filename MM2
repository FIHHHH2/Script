-- Fast role detection (checks tools as fallback with cache)
local function getRole(p)
	local pdRole=playerData and playerData[p.Name] and playerData[p.Name].Role
	if pdRole and pdRole~="Innocent" then return pdRole end
	if detectedRoles[p.Name] then return detectedRoles[p.Name] end

	local c=p.Character; local bp=p:FindFirstChild("Backpack")
	if c then
		if c:FindFirstChild("Knife") or c:FindFirstChild("RealKnife") then 
			detectedRoles[p.Name] = "Murderer"
			return "Murderer" 
		end
		if c:FindFirstChild("Gun") or c:FindFirstChild("RealGun") then 
			detectedRoles[p.Name] = "Sheriff"
			return "Sheriff" 
		end
	end
	if bp then
		if bp:FindFirstChild("Knife") or bp:FindFirstChild("RealKnife") then 
			detectedRoles[p.Name] = "Murderer"
			return "Murderer" 
		end
		if bp:FindFirstChild("Gun") or bp:FindFirstChild("RealGun") then 
			detectedRoles[p.Name] = "Sheriff"
			return "Sheriff" 
		end
	end
	return pdRole or "Innocent"
end
local function getDead(p) return (playerData and playerData[p.Name] and playerData[p.Name].Dead) or false end
local function getChar(p)
	if p and p.Character then
		local c=p.Character; local h=c:FindFirstChildOfClass("Humanoid")
		if h and h.Health>0 and c:FindFirstChild("HumanoidRootPart") then return c end
	end end
local function getRoot(p) local c=getChar(p) return c and c:FindFirstChild("HumanoidRootPart") end
local function getAlive()
	local l={}
	for _,p in Players:GetPlayers() do if p~=LP and getChar(p) then table.insert(l,p) end end
	return l
end

local function getMurderer()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LP and getRole(p) == "Murderer" and not getDead(p) then
			return p
		end
	end
	return nil
end

local function killAll()
	local char = LP.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not (root and hum) then return end

	-- Must have knife (be murderer or hold one)
	local kn = char:FindFirstChild("Knife") or (LP.Backpack and LP.Backpack:FindFirstChild("Knife"))
	if not kn then return end

	task.spawn(function()
		local oldCF = root.CFrame

		if kn.Parent ~= char then
			kn.Parent = char
			task.wait(0.1)
		end

		for _, p in ipairs(Players:GetPlayers()) do
			if p == LP then continue end
			if getDead(p) then continue end

			local pChar = p.Character
			if not pChar then continue end
			local pHum = pChar:FindFirstChildOfClass("Humanoid")
			if not pHum or pHum.Health <= 0 then continue end
			local pRoot = pChar:FindFirstChild("HumanoidRootPart")
			if not pRoot then continue end

			root.CFrame = pRoot.CFrame * CFrame.new(0, 0, 1.5)
			task.wait(0.08)

			kn:Activate()

			local handle = kn:FindFirstChild("Handle")
			if handle then
				firetouchinterest(handle, pRoot, 0)
				firetouchinterest(handle, pRoot, 1)
			end
			task.wait(0.05)
		end

		root.CFrame = oldCF
	end)
end


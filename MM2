-- Fast role detection (checks tools as fallback with cache)
local function getRole(p)
	local pdRole=playerData and playerData[p.Name] and playerData[p.Name].Role
	if pdRole and pdRole~="Innocent" then return pdRole end
	if detectedRoles[p.Name] then return detectedRoles[p.Name] end

	local c=p.Character; local bp=p:FindFirstChild("Backpack")
	if c then
		if c:FindFirstChild("Knife") or c:FindFirstChild("RealKnife") then 
			detectedRoles[p.Name] = "Murderer"
			return "Murderer" 
		end
		if c:FindFirstChild("Gun") or c:FindFirstChild("RealGun") then 
			detectedRoles[p.Name] = "Sheriff"
			return "Sheriff" 
		end
	end
	if bp then
		if bp:FindFirstChild("Knife") or bp:FindFirstChild("RealKnife") then 
			detectedRoles[p.Name] = "Murderer"
			return "Murderer" 
		end
		if bp:FindFirstChild("Gun") or bp:FindFirstChild("RealGun") then 
			detectedRoles[p.Name] = "Sheriff"
			return "Sheriff" 
		end
	end
	return pdRole or "Innocent"
end
local function getDead(p) return (playerData and playerData[p.Name] and playerData[p.Name].Dead) or false end
local function getChar(p)

end
local function followPlayer(p)
	local char = LP.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not (char and root) then return end
	local tChar = p.Character
	local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
	if not tRoot then return end
	-- Toggle off if clicking the same player
	if followActive and followTarget == p then
		stopFollowPlayer()
		return
	end
	-- Make sure Troll Walk and any prior follow loops are stopped
	stopTrollWalk()
	stopFollowPlayer()
	followActive = true
	followTarget = p
	-- Teleport behind first
	root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3)
	followConnection = RSv.RenderStepped:Connect(function()
		if not followActive or not p.Parent or not tRoot.Parent or not root.Parent then
			stopFollowPlayer()
			return
		end
		local tHum = tChar:FindFirstChildOfClass("Humanoid")
		if tHum and tHum.Health <= 0 then
			stopFollowPlayer()
			return
		end
		-- Stay closely on their back (3 studs behind, matching height)
		root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3)
	end)
end

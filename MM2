addSlider(tabConts[7],"BG Alpha",0,100,90,function(v)
	bgT=v/100; local dfl=0.9
	local skip={main,title,foot,side}; for _,c in ipairs(tabConts) do table.insert(skip,c) end
	for _,o in main:GetDescendants() do
		if (o:IsA("Frame") or o:IsA("TextButton")) and not o:IsA("TextLabel") then
			local blocked=false; for _,s in ipairs(skip) do if o==s then blocked=true; break end end
			if not blocked then
				if origTransparencies[o]==nil then origTransparencies[o]=o.BackgroundTransparency end
				local orig=origTransparencies[o]
				if bgT<=dfl then
					o.BackgroundTransparency=orig*(bgT/dfl)
				else
					o.BackgroundTransparency=orig+(1-orig)*((bgT-dfl)/(1-dfl))
				end
			end
		end
	end
end,"%")

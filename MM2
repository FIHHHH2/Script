	if i.KeyCode==Enum.KeyCode.Minus then bhEnabled=not bhEnabled; if toggles["Bunny Hop"] then toggles["Bunny Hop"](bhEnabled) end end
	if i.KeyCode==Enum.KeyCode.RightBracket then gui.Enabled=not gui.Enabled; if toggles["Toggle GUI (])"] then toggles["Toggle GUI (])"](gui.Enabled) end end
	if i.KeyCode==Enum.KeyCode.Equals then espEnabled=not espEnabled; if toggles["ESP Enabled"] then toggles["ESP Enabled"](espEnabled) end end
end))

-- ESP ScreenGui Containers
local espGui = Instance.new("ScreenGui")
espGui.Name = "MM2_ESP_ROUTINE"
espGui.Parent = guiParent
espGui.ResetOnSpawn = false

local espDrawings = {}

local function clearDrawingsFor(key)
	if espDrawings[key] then
		local d = espDrawings[key]
		pcall(function() if d.billboard then d.billboard:Destroy() end end)
		espDrawings[key] = nil
	end
end

local function updateESP()
	if not espEnabled then
		for k, _ in pairs(espDrawings) do
			if typeof(k) == "Instance" and k:IsA("Player") then
				clearDrawingsFor(k)
			end
		end
		return
	end

	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LP then
			local char = p.Character
			local root = char and char:FindFirstChild("HumanoidRootPart")
			local hum = char and char:FindFirstChildOfClass("Humanoid")

			if root and hum and hum.Health > 0 then
				local drawings = espDrawings[p]
				if not drawings then
					-- Billboard setup
					local billboard = Instance.new("BillboardGui")
					billboard.Name = "MM2_ESP_BILLBOARD"
					billboard.AlwaysOnTop = true
					billboard.Size = UDim2.new(0, 140, 0, 44)
					billboard.StudsOffset = Vector3.new(0, 3, 0)
					billboard.Parent = espGui

					-- Premium Dark-Translucent Capsule Container
					local container = Instance.new("Frame")
					container.Size = UDim2.new(1, 0, 1, 0)
					container.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
					container.BackgroundTransparency = 0.35
					container.BorderSizePixel = 0
					container.Parent = billboard

					local corner = Instance.new("UICorner")
					corner.CornerRadius = UDim.new(0, 6)
					corner.Parent = container

					local stroke = Instance.new("UIStroke")
					stroke.Thickness = 1
					stroke.Transparency = 0.4
					stroke.Parent = container

					local list = Instance.new("UIListLayout")
					list.SortOrder = Enum.SortOrder.LayoutOrder
					list.Padding = UDim.new(0, 3)
					list.HorizontalAlignment = Enum.HorizontalAlignment.Center
					list.VerticalAlignment = Enum.VerticalAlignment.Center
					list.Parent = container

					-- Header row (Name and Distance)
					local header = Instance.new("Frame")
					header.Size = UDim2.new(1, 0, 0, 15)
					header.BackgroundTransparency = 1
					header.Parent = container

					local hList = Instance.new("UIListLayout")
					hList.FillDirection = Enum.FillDirection.Horizontal
					hList.HorizontalAlignment = Enum.HorizontalAlignment.Center
					hList.VerticalAlignment = Enum.VerticalAlignment.Center
					hList.Padding = UDim.new(0, 4)
					hList.Parent = header

					local nameLabel = Instance.new("TextLabel")
					nameLabel.AutomaticSize = Enum.AutomaticSize.X
					nameLabel.Size = UDim2.new(0, 0, 1, 0)
					nameLabel.BackgroundTransparency = 1
					nameLabel.Font = Enum.Font.GothamBold
					nameLabel.TextSize = 10
					nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
					nameLabel.Parent = header

					local distLabel = Instance.new("TextLabel")
					distLabel.AutomaticSize = Enum.AutomaticSize.X
					distLabel.Size = UDim2.new(0, 0, 1, 0)
					distLabel.BackgroundTransparency = 1
					distLabel.Font = Enum.Font.Gotham
					distLabel.TextSize = 8
					distLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
					distLabel.Parent = header

					-- Role Badge (Mini pill container)
					local badge = Instance.new("Frame")
					badge.Size = UDim2.new(0, 75, 0, 14)
					badge.Parent = container

					local bCorner = Instance.new("UICorner")
					bCorner.CornerRadius = UDim.new(1, 0)
					bCorner.Parent = badge

					local bStroke = Instance.new("UIStroke")
					bStroke.Thickness = 1
					bStroke.Transparency = 0.2
					bStroke.Parent = badge

					local roleLabel = Instance.new("TextLabel")
					roleLabel.Size = UDim2.new(1, 0, 1, 0)
					roleLabel.BackgroundTransparency = 1
					roleLabel.Font = Enum.Font.GothamBold
					roleLabel.TextSize = 8
					roleLabel.Parent = badge

					drawings = {
						billboard = billboard,
						container = container,
						stroke = stroke,
						nameLabel = nameLabel,
						distLabel = distLabel,
						badge = badge,
						bStroke = bStroke,
						roleLabel = roleLabel
					}
					espDrawings[p] = drawings
				end

				local head = char:FindFirstChild("Head") or root
				drawings.billboard.Adornee = head

				local myChar = LP.Character
				local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
				local dist = myRoot and (myRoot.Position - root.Position).Magnitude or 0
				local role = getRole(p)
				local dead = (playerData and playerData[p.Name] and playerData[p.Name].Dead) or false

				local col
				local roleStatusText = "Innocent"

				if dead then 
					col = Color3.fromRGB(150, 150, 150)
					roleStatusText = "Dead"
				elseif role == "Murderer" then 
					col = Color3.fromRGB(235, 60, 60)
					roleStatusText = "Murderer"
				elseif role == "Sheriff" then 
					col = Color3.fromRGB(60, 150, 235)
					roleStatusText = "Sheriff"
				else 
					col = Color3.fromRGB(80, 220, 80) 
				end

				-- Apply role indicator colors to border strokes and badges
				drawings.stroke.Color = col
				drawings.bStroke.Color = col
				drawings.roleLabel.TextColor3 = col

				-- Populate content
				drawings.nameLabel.Text = p.Name
				drawings.distLabel.Text = espShowDist and (math.floor(dist) .. "m") or ""
				drawings.distLabel.Visible = espShowDist

				drawings.roleLabel.Text = string.upper(roleStatusText)
				drawings.badge.BackgroundColor3 = col
				drawings.badge.BackgroundTransparency = 0.85
				drawings.badge.Visible = espShowRole

				drawings.billboard.Enabled = true
			else
				clearDrawingsFor(p)
			end
		end
	end

	-- Cleanup left players
	for p, _ in pairs(espDrawings) do
		if typeof(p) == "Instance" and p:IsA("Player") and not Players:FindFirstChild(p.Name) then
			clearDrawingsFor(p)
		end
	end
end

ac(RSv.RenderStepped:Connect(updateESP))

local function updateWepESP()
	if not wepEsp then
		for k, _ in pairs(espDrawings) do
			if typeof(k) == "string" and string.sub(k, 1, 4) == "wep_" then
				clearDrawingsFor(k)
			end
		end
		return
	end

	local seen = {}
	local myChar = LP.Character
	local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

	for _, v in ipairs(workspace:GetChildren()) do
		if v.Name == "GunDrop" or v.Name == "DroppedGun" or (v:IsA("Tool") and v.Name == "Gun" and v.Parent == workspace) then
			local handle = v:FindFirstChild("Handle") or v:FindFirstChildOfClass("Part") or v:FindFirstChildOfClass("MeshPart") or v
			if handle then
				local id = "wep_" .. v:GetDebugId()
				seen[id] = true

				local drawings = espDrawings[id]
				if not drawings then
					local billboard = Instance.new("BillboardGui")
					billboard.Name = "MM2_Wep_Billboard"
					billboard.AlwaysOnTop = true
					billboard.Size = UDim2.new(0, 110, 0, 32)
					billboard.StudsOffset = Vector3.new(0, 1.5, 0)
					billboard.Parent = espGui

					local label = Instance.new("TextLabel")
					label.Size = UDim2.new(1, 0, 1, 0)
					label.BackgroundTransparency = 1
					label.TextColor3 = Color3.fromRGB(80, 180, 255)
					label.Font = Enum.Font.ArimoBold
					label.TextSize = 11
					label.TextStrokeTransparency = 0
					label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
					label.Parent = billboard

					drawings = {billboard = billboard, label = label}
					espDrawings[id] = drawings
				end

				drawings.billboard.Adornee = handle
				local dist = myRoot and (myRoot.Position - handle.Position).Magnitude or 0
				drawings.label.Text = "GUN\n[" .. math.floor(dist) .. " studs]"
				drawings.billboard.Enabled = true
			end
		end
	end

	-- Clean inactive weapons
	for id, _ in pairs(espDrawings) do
		if typeof(id) == "string" and string.sub(id, 1, 4) == "wep_" and not seen[id] then
			clearDrawingsFor(id)
		end
	end
end

local function getActiveCoins()
	local list = {}
	local containers = {}
	for _, v in ipairs(workspace:GetChildren()) do
		if v.Name == "Normal" or v.Name == "Map" or v:IsA("Model") then
			local cc = v:FindFirstChild("CoinContainer", true)
			if cc then table.insert(containers, cc) end
		end
	end
	local coinContainer = workspace:FindFirstChild("CoinContainer", true)
	if coinContainer then table.insert(containers, coinContainer) end

	if #containers > 0 then
		for _, container in ipairs(containers) do
			for _, child in ipairs(container:GetChildren()) do
				if child:IsA("BasePart") and (child.Name == "Coin" or child.Name == "Coin_Server") and child:FindFirstChild("TouchInterest") then
					table.insert(list, child)
				end
			end
		end
	else
		for _, child in ipairs(workspace:GetChildren()) do
			if child.Name == "Normal" or child.Name == "Map" or child:IsA("Model") then
				for _, sub in ipairs(child:GetDescendants()) do
					if sub:IsA("BasePart") and (sub.Name == "Coin" or sub.Name == "Coin_Server") and sub:FindFirstChild("TouchInterest") then
						table.insert(list, sub)
					end
				end
			end
		end
	end
	return list
end

local function updateCoinESP()
	if not coinEsp then
		for k, _ in pairs(espDrawings) do
			if typeof(k) == "string" and string.sub(k, 1, 5) == "coin_" then
				clearDrawingsFor(k)
			end
		end
		return
	end

	local seen = {}
	local active = getActiveCoins()

	for _, v in ipairs(active) do
		local id = "coin_" .. v:GetDebugId()
		seen[id] = true

		local drawings = espDrawings[id]
		if not drawings then
			local billboard = Instance.new("BillboardGui")
			billboard.Name = "MM2_Coin_Billboard"
			billboard.AlwaysOnTop = true
			billboard.Size = UDim2.new(0, 60, 0, 18)
			billboard.Parent = espGui

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1, 0, 1, 0)
			label.BackgroundTransparency = 1
			label.TextColor3 = Color3.fromRGB(255, 200, 50)
			label.Font = Enum.Font.ArimoBold
			label.TextSize = 10
			label.Text = "COIN"
			label.TextStrokeTransparency = 0
			label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
			label.Parent = billboard

			drawings = {billboard = billboard, label = label}
			espDrawings[id] = drawings
		end

		drawings.billboard.Adornee = v
		drawings.billboard.Enabled = true
	end

	-- Clean inactive coins
	for id, _ in pairs(espDrawings) do
		if typeof(id) == "string" and string.sub(id, 1, 5) == "coin_" and not seen[id] then
			clearDrawingsFor(id)
		end
	end
end

-- Real-time weapon detection
ac(workspace.DescendantAdded:Connect(function(v)
	if v:IsA("Tool") then
		local function checkParent()
			local p=v.Parent
			while p do
				if p:IsA("Model") and p:FindFirstChildOfClass("Humanoid") then return end
				if p==workspace then pcall(updateWepESP); return end
				p=p.Parent
			end
		end
		checkParent()
	end
end))
task.spawn(function()
	while wait(0.3) do
		pcall(updateWepESP)
		pcall(updateCoinESP)
	end
end)


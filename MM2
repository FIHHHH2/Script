local espF=Instance.new("Folder"); espF.Name="MM2ESP"; espF.Parent=CG
local espO={}
local function updateESP()
	if not espEnabled then
		for _,o in pairs(espO) do if o and o.bg then o.bg.Enabled=false end end
		return
	end
	local myPos=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
	for _,p in ipairs(Players:GetPlayers()) do
		if p ~= LP then
			local char = p.Character
			local root = char and char:FindFirstChild("HumanoidRootPart")
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			if root and hum and hum.Health > 0 then
				local o = espO[p]
				if not o or not o.bg or o.bg.Parent == nil then
					if o and o.bg then pcall(function() o.bg:Destroy() end) end
					local bg=Instance.new("BillboardGui"); bg.Name=p.Name; bg.Size=UDim2.new(0,200,0,60); bg.StudsOffset=Vector3.new(0,3,0)
					bg.AlwaysOnTop=true; bg.Adornee=root; bg.Parent=espF
					local nl=Instance.new("TextLabel"); nl.Size=UDim2.new(1,0,0,18); nl.BackgroundTransparency=0.3; nl.BackgroundColor3=Color3.new(0,0,0)
					nl.TextColor3=Color3.new(1,1,1); nl.Text=p.Name; nl.Font=Enum.Font.ArimoBold; nl.TextSize=14; nl.TextStrokeTransparency=0; nl.Parent=bg
					local rl=Instance.new("TextLabel"); rl.Size=UDim2.new(1,0,0,16); rl.Position=UDim2.new(0,0,0,18)
					rl.BackgroundTransparency=0.3; rl.BackgroundColor3=Color3.new(0,0,0); rl.TextColor3=Color3.new(1,1,1); rl.Text=""
					rl.Font=Enum.Font.ArimoBold; rl.TextSize=13; rl.TextStrokeTransparency=0; rl.Parent=bg
					local dl=Instance.new("TextLabel"); dl.Size=UDim2.new(1,0,0,16); dl.Position=UDim2.new(0,0,0,34)
					dl.BackgroundTransparency=0.3; dl.BackgroundColor3=Color3.new(0,0,0); dl.TextColor3=Color3.new(0.8,0.8,0.8); dl.Text=""
					dl.Font=Enum.Font.ArimoBold; dl.TextSize=12; dl.TextStrokeTransparency=0; dl.Parent=bg
					espO[p]={bg=bg,nl=nl,rl=rl,dl=dl,plr=p}
					o = espO[p]
				end
				o.bg.Enabled=true
				o.bg.Adornee=root
				local role=getRole(p)
				local dead=(playerData and playerData[p.Name] and playerData[p.Name].Dead) or false
				local dist=myPos and (myPos.Position-root.Position).Magnitude or 0
				local col
				if dead then col=Color3.new(0.5,0.5,0.5); role=role.." (Dead)"
				elseif highlVics and currentRole=="Murderer" and role~="Murderer" then col=Color3.new(1,0.4,1)
				elseif role=="Murderer" then col=Color3.fromRGB(255,50,50)
				elseif role=="Sheriff" then col=Color3.fromRGB(50,150,255)
				else col=Color3.fromRGB(50,255,50) end
				o.nl.TextColor3=col; o.nl.Text=p.Name.." ["..math.floor(dist).."m]"
				o.rl.Text=espShowRole and role or ""; o.dl.Text=espShowDist and math.floor(dist).." studs" or ""
			else
				local o = espO[p]
				if o and o.bg then o.bg.Enabled=false end
			end
		end
	end
	for p,o in pairs(espO) do
		if not Players:FindFirstChild(p.Name) then
			if o.bg then pcall(function() o.bg:Destroy() end) end
			espO[p]=nil
		end
	end
end

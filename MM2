local camDist=12
local function camBehind(tr)
	if not tr then return end
	local lv=CAM.CFrame.LookVector
	local headPos=tr.Position+Vector3.new(0,3,0)
	CAM.CFrame=CFrame.lookAt(headPos-lv*camDist,headPos)
end
UIS.InputChanged:Connect(function(i)
	if i.UserInputType==Enum.UserInputType.MouseWheel then
		camDist=math.clamp(camDist-i.Position.Z*2,3,60)
	end
end)
local occludedParts={}
local function clearOccluded()
	for p,t in pairs(occludedParts) do
		if p and p.Parent then p.Transparency=t end
	end
	occludedParts={}
end
local function handleOcclusion(from,to)
	local params=RaycastParams.new()
	params.FilterType=Enum.RaycastFilterType.Blacklist
	local filter={LP.Character,CAM}
	params.FilterDescendantsInstances=filter
	local result=workspace:Raycast(from,(to-from).Unit*((to-from).Magnitude),params)
	local hit=result and result.Instance and (result.Instance:IsA("BasePart") or result.Instance:IsA("UnionOperation") or result.Instance:IsA("MeshPart")) and result.Instance
	for p,t in pairs(occludedParts) do
		if p~=hit and p.Parent then p.Transparency=t end
		if p~=hit then occludedParts[p]=nil end
	end
	if hit and not occludedParts[hit] then
		occludedParts[hit]=hit.Transparency
		hit.Transparency=1
	end
end

local function stopTrollWalk()
	trollWalkActive = false
	if trollWalkConnection then
		trollWalkConnection:Disconnect()
		trollWalkConnection = nil
	end
	if trollWalkTrack then
		trollWalkTrack:Stop()
		trollWalkTrack:Destroy()
		trollWalkTrack = nil
	end
	currentTrollTarget = nil
	clearOccluded()
end

local function trollWalkOnPlayer(p)
	local char = LP.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not (char and root and hum) then return end

	local tChar = p.Character
	local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
	if not tRoot then return end

	-- Toggle off if clicking the same player again
	if trollWalkActive and currentTrollTarget == p then
		stopTrollWalk()
		return
	end

	stopTrollWalk()

	trollWalkActive = true
	currentTrollTarget = p

	-- Play walk animation fallback
	local animate = char:FindFirstChild("Animate")
	local walkTrackVal = animate and animate:FindFirstChild("walk")
	local walkAnim = walkTrackVal and walkTrackVal:FindFirstChildOfClass("Animation")
	if walkAnim then
		pcall(function()
			trollWalkTrack = hum:LoadAnimation(walkAnim)
			trollWalkTrack.Looped = true
			trollWalkTrack:Play()
		end)
	end

	-- Teleport behind player first
	root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3.5)

	-- Keep teleporting behind player with back-and-forth movement
	trollWalkConnection = RSv.RenderStepped:Connect(function()
		if not trollWalkActive or not p.Parent or not root.Parent then
			stopTrollWalk()
			return
		end

		-- Dynamic character lookup (handles target respawning)
		local currentTargetChar = p.Character
		local currentTargetRoot = currentTargetChar and currentTargetChar:FindFirstChild("HumanoidRootPart")
		local currentTargetHum = currentTargetChar and currentTargetChar:FindFirstChildOfClass("Humanoid")

		-- If they are dead or respawning, wait for them to load back in
		if not currentTargetRoot or not currentTargetHum or currentTargetHum.Health <= 0 then
			return
		end

		local offsetZ = 3.5 + math.sin(tick() * trollSpeed) * 2
		root.CFrame = currentTargetRoot.CFrame * CFrame.new(0, 0, offsetZ)
		camBehind(currentTargetRoot)
		handleOcclusion(CAM.CFrame.Position,currentTargetRoot.Position)
	end)
end

local function followPlayer(p)
	local char = LP.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not (char and root) then return end

	local tChar = p.Character
	local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
	if not tRoot then return end

	if followActive and followTarget == p then
		stopFollowPlayer()
		return
	end

	stopTrollWalk()
	stopFlingPlayer()
	stopFollowPlayer()

	followActive = true
	followTarget = p

	root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3)

	followConnection = RSv.RenderStepped:Connect(function()
		if not followActive or not p.Parent or not root.Parent then
			stopFollowPlayer()
			return
		end

		local currentTargetChar = p.Character
		local currentTargetRoot = currentTargetChar and currentTargetChar:FindFirstChild("HumanoidRootPart")
		local currentTargetHum = currentTargetChar and currentTargetChar:FindFirstChildOfClass("Humanoid")

		if not currentTargetRoot or not currentTargetHum or currentTargetHum.Health <= 0 then
			return
		end

		-- Disable collisions during follow to prevent physics glitches
		local myChar = LP.Character
		if myChar then
			for _, part in ipairs(myChar:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CanCollide = false
				end
			end
		end

		root.CFrame = currentTargetRoot.CFrame * CFrame.new(0, 0, 3)
	end)
end

local function toggleFling(p)
	local char = LP.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not (char and root and hum) then return end

	if flingActive and flingTarget == p then
		stopFlingPlayer()
		return
	end

	stopTrollWalk()
	stopFollowPlayer()
	stopFlingPlayer()

	flingActive = true
	flingTarget = p

	task.spawn(function()
		local originalCF = root.CFrame
		local originalVelocity = root.Velocity
		local originalRot = root.RotVelocity

		local bav = Instance.new("BodyAngularVelocity")
		bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
		bav.AngularVelocity = Vector3.new(0, 99999, 0)
		bav.Parent = root

		local conn = RSv.RenderStepped:Connect(function()
			if char then
				for _, part in ipairs(char:GetDescendants()) do
					if part:IsA("BasePart") then
						-- Keep HumanoidRootPart collidable so it can transfer force
						if part.Name == "HumanoidRootPart" then
							part.CanCollide = true
						else
							part.CanCollide = false
						end
					end
				end
			end
		end)

		while flingActive and p.Parent and root.Parent and hum.Health > 0 do
			local tChar = p.Character
			local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
			local tHum = tChar and tChar:FindFirstChildOfClass("Humanoid")

			if tRoot and tHum and tHum.Health > 0 then
				root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 0.1)
				root.Velocity = Vector3.new(99999, 99999, 99999)
				pcall(function()
					root.AssemblyLinearVelocity = Vector3.new(99999, 99999, 99999)
					root.AssemblyAngularVelocity = Vector3.new(0, 99999, 0)
				end)
			else
				break
			end
			task.wait()
		end

		conn:Disconnect()
		if bav then pcall(function() bav:Destroy() end) end
		root.Velocity = originalVelocity
		root.RotVelocity = originalRot
		root.CFrame = originalCF
		stopFlingPlayer()
	end)
end


local function addSlider(s,label,mi,ma,init,cb,suf)
	local r=Instance.new("Frame"); r.Size=UDim2.new(1,-10,0,38); r.BackgroundTransparency=1; r.Parent=s
	local lay=Instance.new("UIListLayout"); lay.FillDirection=Enum.FillDirection.Horizontal; lay.VerticalAlignment=Enum.VerticalAlignment.Center; lay.Padding=UDim.new(0,8); lay.SortOrder=Enum.SortOrder.LayoutOrder; lay.Parent=r
	local l=Instance.new("TextLabel"); l.Size=UDim2.new(0,120,0,20); l.BackgroundTransparency=1
	l.TextColor3=L.text; l.Text=label; l.Font=Enum.Font.ArimoBold; l.TextSize=13; l.TextXAlignment=Enum.TextXAlignment.Left; l.Parent=r
	local sb=Instance.new("Frame"); sb.Size=UDim2.new(1,-195,0,12); sb.BackgroundColor3=Color3.fromRGB(40,40,40); sb.BorderSizePixel=0; sb.Parent=r
	Instance.new("UICorner",sb).CornerRadius=UDim.new(0,6)
	local sf=Instance.new("Frame"); sf.Size=UDim2.new(0.5,0,1,0); sf.BackgroundColor3=Color3.fromRGB(80,160,255); sf.BorderSizePixel=0; sf.Parent=sb
	Instance.new("UICorner",sf).CornerRadius=UDim.new(0,6)
	local kn=Instance.new("Frame"); kn.Size=UDim2.new(0,20,0,20); kn.Position=UDim2.new(0.5,-10,0,-5)
	kn.BackgroundColor3=Color3.fromRGB(220,220,220); kn.BorderSizePixel=0; kn.Parent=sb
	Instance.new("UICorner",kn).CornerRadius=UDim.new(0,10)
	local vl=Instance.new("TextLabel"); vl.Size=UDim2.new(0,55,0,20); vl.BackgroundTransparency=1
	vl.TextColor3=Color3.fromRGB(80,160,255); vl.Text=tostring(init)..(suf or "")
	vl.Font=Enum.Font.ArimoBold; vl.TextSize=13; vl.TextXAlignment=Enum.TextXAlignment.Right; vl.Parent=r
	local val=init; local dragging=false
	local function upd(x)
		local ax=x-sb.AbsolutePosition.X; local w=sb.AbsoluteSize.X; if w<=0 then w=1 end
		local fr=math.clamp(ax/w,0,1); val=mi+(ma-mi)*fr
		if math.abs(ma-mi)>=10 then val=math.round(val) end
		val=math.clamp(val,mi,ma)
		sf.Size=UDim2.new((val-mi)/(ma-mi),0,1,0); kn.Position=UDim2.new((val-mi)/(ma-mi),-10,0,-5)
		vl.Text=tostring(val)..(suf or ""); if cb then pcall(function() cb(val) end) end
	end
	sb.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; upd(i.Position.X) end end)
	sb.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
	ac(UIS.InputChanged:Connect(function(i) if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement) then upd(i.Position.X) end end))
	s.CanvasSize=UDim2.new(0,0,0,s.UIListLayout.AbsoluteContentSize.Y+10)
	return r
end


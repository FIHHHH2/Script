local function recalcBtnHeight()
	local sh = side.AbsoluteSize.Y
	if sh <= 0 then return end
	btnHeightProp = (sh - TAB_PAD * (TAB_COUNT - 1) - 8) / TAB_COUNT
	local s = btnHeightProp / BASE_BTN_H
	for i, btn in ipairs(tabBtns) do
		btn.Size = UDim2.new(1, 0, 0, btnHeightProp)
		local ic = btn:FindFirstChild("Icon")
		local lb = btn:FindFirstChild("Label")
		if ic then
			ic.Size = UDim2.new(1, 0, 0, 24 * s)
			ic.Position = UDim2.new(0, 0, 0, 8 * s)
			ic.TextSize = 16 * s
		end
		if lb then
			lb.Size = UDim2.new(1, -4, 0, 18 * s)
			lb.Position = UDim2.new(0, 2, 0, 30 * s)
			lb.TextSize = 10 * s
		end
	end
end


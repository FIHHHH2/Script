local function getNearestOnScreen(f, checkMurdererOnly)
	local n,nd=nil,f or math.huge
	for _,p in getAlive() do
		if checkMurdererOnly and getRole(p) ~= "Murderer" then continue end
		local r=getRoot(p)
		if r then
			local sp,on=CAM:WorldToViewportPoint(r.Position)
			if on then
				local d=(Vector2.new(sp.X,sp.Y)-Vector2.new(CAM.ViewportSize.X/2,CAM.ViewportSize.Y/2)).Magnitude
				if d<nd then n=p; nd=d end
			end
		end
	end
	return n,nd
end
local function getSilentAimTarget()
	local c=LP.Character; if not c then return nil, nil end
	local hasGun=c:FindFirstChild("Gun")
	local hasKnife=c:FindFirstChild("Knife")
	if not (hasGun or hasKnife) then return nil, nil end
	if autoKillMurderer and hasGun then
		local mud = getMurderer()
		if mud and mud.Character then
			local r = getRoot(mud)
			if r then
				local head = mud.Character:FindFirstChild("Head")
				return CFrame.new(head and head.Position or r.Position), head or r
			end
		end
	end
	if not silAim then return nil, nil end

	local checkMurdererOnly=false
	if hasGun or currentRole=="Sheriff" or currentRole=="Hero" then
		checkMurdererOnly=true
	end

	local target,dist=getNearestOnScreen(silFOV,checkMurdererOnly)
	if target and target.Character then
		local targetRoot=getRoot(target)
		if targetRoot then
			local tp=targetRoot.Position
			local head=target.Character:FindFirstChild("Head")
			if head then tp=head.Position end

			if hasKnife then
				local knifeSpeed=40
				local myPos=CAM.CFrame.Position
				local targetVel=targetRoot.AssemblyLinearVelocity
				local t=(tp-myPos).Magnitude/knifeSpeed
				tp=tp+targetVel*t
				local drop=14*t*t
				tp=tp+Vector3.new(0,drop,0)
			end
			return CFrame.new(tp),head or targetRoot
		end
	end
	return nil, nil
end

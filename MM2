local wepF=Instance.new("Folder"); wepF.Name="MM2WeaponESP"; wepF.Parent=CG
local wepO={}
local wepTracked={}
local function updateWepESP()
	if not wepEsp then
		for _,o in pairs(wepO) do if o and o.bg then o.bg.Enabled=false end end
		return
	end
	for _,o in pairs(wepO) do if o and o.bg then o.bg.Enabled=false end end
	local seen={}
	-- Detect only dropped guns in workspace
	for _, v in ipairs(workspace:GetChildren()) do
		if v.Name == "GunDrop" or v.Name == "DroppedGun" or (v:IsA("Tool") and v.Name == "Gun" and v.Parent == workspace) then
			local handle = v:FindFirstChild("Handle") or v:FindFirstChildOfClass("Part") or v:FindFirstChildOfClass("MeshPart") or v
			if handle then
				local id = v:GetDebugId()
				seen[id] = true
				if not wepTracked[id] then
					wepTracked[id] = true
					local bg = Instance.new("BillboardGui"); bg.Size = UDim2.new(0, 160, 0, 40); bg.StudsOffset = Vector3.new(0, 2.5, 0)
					bg.AlwaysOnTop = true; bg.Adornee = handle; bg.Parent = wepF
					local nl = Instance.new("TextLabel"); nl.Size = UDim2.new(1, 0, 0, 20); nl.BackgroundTransparency = 0.4; nl.BackgroundColor3 = Color3.new(0, 0, 0)
					nl.TextColor3 = Color3.fromRGB(50, 150, 255)
					nl.Text = "DROPPED GUN"
					nl.Font = Enum.Font.ArimoBold; nl.TextSize = 12; nl.TextStrokeTransparency = 0; nl.Parent = bg
					local dl = Instance.new("TextLabel"); dl.Size = UDim2.new(1, 0, 0, 16); dl.Position = UDim2.new(0, 0, 0, 20)
					dl.BackgroundTransparency = 0.4; dl.BackgroundColor3 = Color3.new(0, 0, 0); dl.TextColor3 = Color3.fromRGB(200, 200, 200); dl.Text = ""
					dl.Font = Enum.Font.ArimoBold; dl.TextSize = 11; dl.TextStrokeTransparency = 0; dl.Parent = bg
					wepO[id] = {bg = bg, nl = nl, dl = dl, handle = handle}
				else
					local o = wepO[id]
					if o then
						o.bg.Enabled = true
						o.bg.Adornee = handle
						local mp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
						local dist = mp and (mp.Position - handle.Position).Magnitude or 0
						o.dl.Text = math.floor(dist) .. " studs"
					end
				end
			end
		end
	end
	for id,o in pairs(wepO) do
		if not seen[id] then
			wepTracked[id]=nil
			if o.bg then pcall(function() o.bg:Destroy() end) end
			wepO[id]=nil
		end
	end
end
local function getActiveCoins()
	local list = {}
	local containers = {}
	for _, v in ipairs(workspace:GetChildren()) do
		if v.Name == "Normal" or v.Name == "Map" or v:IsA("Model") then
			local cc = v:FindFirstChild("CoinContainer", true)
			if cc then table.insert(containers, cc) end
		end
	end
	local coinContainer = workspace:FindFirstChild("CoinContainer", true)
	if coinContainer then table.insert(containers, coinContainer) end
	if #containers > 0 then
		for _, container in ipairs(containers) do
			for _, child in ipairs(container:GetChildren()) do
				if child:IsA("BasePart") and (child.Name == "Coin" or child.Name == "Coin_Server") and child:FindFirstChild("TouchInterest") then
					table.insert(list, child)
				end
			end
		end
	else
		for _, child in ipairs(workspace:GetChildren()) do
			if child.Name == "Normal" or child.Name == "Map" or child:IsA("Model") then
				for _, sub in ipairs(child:GetDescendants()) do
					if sub:IsA("BasePart") and (sub.Name == "Coin" or sub.Name == "Coin_Server") and sub:FindFirstChild("TouchInterest") then
						table.insert(list, sub)
					end
				end
			end
		end
	end
	return list
end

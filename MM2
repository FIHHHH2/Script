ac(RSv.RenderStepped:Connect(function()
	local c=LP.Character; if not c then return end
	local h=c:FindFirstChildOfClass("Humanoid"); if not h then return end
	if wsEnabled then h.WalkSpeed=wsVal else h.WalkSpeed=16 end
	if jpEnabled then h.JumpPower=jpVal else h.JumpPower=50 end
	if ncEnabled then for _,p in c:GetDescendants() do if p:IsA("BasePart") then p.CanCollide=false end end end
	if fovEnabled then CAM.FieldOfView=fovVal else CAM.FieldOfView=70 end
	-- Aimbot
	if aimEnabled then
		local isSheriff = (currentRole == "Sheriff" or currentRole == "Hero" or (c:FindFirstChild("Gun")) or (LP.Backpack and LP.Backpack:FindFirstChild("Gun")))
		local t=getNearestOnScreen(aimFOV, isSheriff)
		if t then
			local r=getRoot(t)
			if r then
				local tp=r.Position+Vector3.new(0,2,0)
				if t.Character and t.Character:FindFirstChild("Head") then tp=t.Character.Head.Position end
				CAM.CFrame=CAM.CFrame:Lerp(CFrame.new(CAM.CFrame.Position,tp),0.3)
			end
		end
	end
	-- Murderer: auto-stab
	if autoStab and currentRole=="Murderer" then
		local kn=c:FindFirstChild("Knife") or (LP.Backpack and LP.Backpack:FindFirstChild("Knife"))
		if kn then
			if not c:FindFirstChild("Knife") then h:EquipTool(kn) end
			local mp=c:FindFirstChild("HumanoidRootPart")
			if mp then
				local closest,cd=nil,stabReach
				for _,p in getAlive() do
					local r=getRoot(p)
					if r then
						local d=(mp.Position-r.Position).Magnitude
						if d<cd then closest=p; cd=d end
					end
				end
				if closest and kn:IsA("Tool") then
					local r=getRoot(closest)
					if r then
						CAM.CFrame=CFrame.new(CAM.CFrame.Position,r.Position)
						local old=kn.Activated
						kn:Activate()
					end
				end
			end
		end
	end
	-- Murderer: knife aimbot (no wallbang)
	if knifeAim and currentRole=="Murderer" then
		local kn=c:FindFirstChild("Knife")
		if kn then
			local n=getNearestOnScreen(aimFOV)
			if n then
				local r=getRoot(n)
				if r then
					local tp=r.Position+Vector3.new(0,2,0)
					if n.Character and n.Character:FindFirstChild("Head") then tp=n.Character.Head.Position end

					-- Knife throw prediction
					local knifeSpeed=40
					local myPos=CAM.CFrame.Position
					local targetVel=r.AssemblyLinearVelocity
					local t=(tp-myPos).Magnitude/knifeSpeed
					tp=tp+targetVel*t
					local drop=14*t*t
					tp=tp+Vector3.new(0,drop,0)

					local params=RaycastParams.new(); params.FilterType=Enum.RaycastFilterType.Blacklist; params.FilterDescendantsInstances={LP.Character,n.Character}
					local dir=(tp-CAM.CFrame.Position).Unit; local dist=(tp-CAM.CFrame.Position).Magnitude
					local hit=workspace:Raycast(CAM.CFrame.Position,dir*dist,params)
					if not hit then
						CAM.CFrame=CAM.CFrame:Lerp(CFrame.new(CAM.CFrame.Position,tp),0.5)
					end
				end
			end
		end
		-- Sheriff Auto-Kill Murderer
		if autoKillMurderer and (currentRole == "Sheriff" or currentRole == "Hero" or c:FindFirstChild("Gun") or (LP.Backpack and LP.Backpack:FindFirstChild("Gun"))) then
			local mud = getMurderer()
			if mud then
				local r = getRoot(mud)
				if r then
					local gun = c:FindFirstChild("Gun") or (LP.Backpack and LP.Backpack:FindFirstChild("Gun"))
					if gun then
						if not c:FindFirstChild("Gun") then
							gun.Parent = c
						else
							local tp = r.Position
							if mud.Character and mud.Character:FindFirstChild("Head") then tp = mud.Character.Head.Position end
							CAM.CFrame = CAM.CFrame:Lerp(CFrame.new(CAM.CFrame.Position, tp), 0.3)
							if tick() - lastShotTime > 0.5 then
								lastShotTime = tick()
								gun:Activate()
							end
						end
					end
				end
			end
		end
		-- Murderer Knife Alert
		if knifeAlert then
			local mud = getMurderer()
			local kn = mud and mud.Character and (mud.Character:FindFirstChild("Knife") or mud.Character:FindFirstChild("RealKnife"))
			if kn then
				foot.Text = "  ⚠️ MURDERER HAS KNIFE OUT! (" .. mud.Name .. ") ⚠️"
				foot.TextColor3 = Color3.fromRGB(255, 50, 50)
			else
				foot.Text = "  - \u{1F412}  ] \u{1F5E1}  = \u{1F441}  |  v1.0"
				foot.TextColor3 = Color3.fromRGB(140, 140, 140)
			end
		end
		updateFOVCircle()
	end
end))

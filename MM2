local toggles={}
local function addTog(s,label,init,cb)
	local r=Instance.new("Frame"); r.Size=UDim2.new(1,-10,0,34); r.BackgroundTransparency=1; r.Parent=s
	local l=Instance.new("TextLabel"); l.Size=UDim2.new(1,-60,1,0); l.Position=UDim2.new(0,6,0,0); l.BackgroundTransparency=1
	l.TextColor3=L.text; l.Text=label; l.Font=Enum.Font.ArimoBold; l.TextSize=13; l.TextXAlignment=Enum.TextXAlignment.Left; l.Parent=r
	local b=Instance.new("TextButton"); b.Size=UDim2.new(0,52,0,26); b.Position=UDim2.new(1,-62,0,4)
	b.BackgroundColor3=init and L.accent or Color3.fromRGB(40,40,40)
	b.TextColor3=init and Color3.fromRGB(255,255,255) or Color3.fromRGB(180,180,180)
	b.Text=init and "ON" or "OFF"
	b.Font=Enum.Font.ArimoBold; b.TextSize=11; b.BorderSizePixel=0; b.Parent=r
	Instance.new("UICorner",b).CornerRadius=UDim.new(0,6)
	local st=init
	local function set(v)
		st=v; b.BackgroundColor3=st and L.accent or Color3.fromRGB(40,40,40)
		b.TextColor3=st and Color3.fromRGB(255,255,255) or Color3.fromRGB(180,180,180); b.Text=st and "ON" or "OFF"
		if cb then pcall(function() cb(st) end) end
	end
	b.MouseButton1Click:Connect(function() set(not st) end)
	toggles[label]=set
	s.CanvasSize=UDim2.new(0,0,0,s.UIListLayout.AbsoluteContentSize.Y+10)
	return r
end

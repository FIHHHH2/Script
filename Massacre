local airSwimEnabled = false
local swimSpeedVal = 50

createToggleRow(playerContainer, "AirSwim", "Air Swim", 144, false, function(state)
	airSwimEnabled = state
	if state then
		local uis = UserInputService
		local tick = 0
		local bv = Instance.new("BodyVelocity")
		bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
		bv.P = 1e9
		local conn
		conn = RunService.Heartbeat:Connect(function()
			if not airSwimEnabled then
				conn:Disconnect()
				if bv and bv.Parent then bv:Destroy() end
				local c = LocalPlayer.Character
				if c then
					local hum = c:FindFirstChildOfClass("Humanoid")
					if hum then
						hum.HipHeight = 0
						hum:ChangeState(Enum.HumanoidStateType.Running)
					end
				end
				return
			end
			local c = LocalPlayer.Character
			if not c then return end
			local hrp = c:FindFirstChild("HumanoidRootPart")
			local hum = c:FindFirstChildOfClass("Humanoid")
			if not hrp or not hum then return end

			bv.Parent = hrp
			hum.WalkSpeed = swimSpeedVal
			hum.HipHeight = 3.5
			hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, true)

			local swim = pcall(function() hum:ChangeState(Enum.HumanoidStateType.Swimming) end)

			tick = tick + 1
			local bob = math.sin(tick * 0.08) * 0.8

			local moveDir = Vector3.new(
				(uis:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (uis:IsKeyDown(Enum.KeyCode.A) and 1 or 0),
				(uis:IsKeyDown(Enum.KeyCode.Space) and 1 or 0) - (uis:IsKeyDown(Enum.KeyCode.LeftShift) and 1 or 0),
				(uis:IsKeyDown(Enum.KeyCode.S) and 1 or 0) - (uis:IsKeyDown(Enum.KeyCode.W) and 1 or 0)
			)
			if moveDir.Magnitude > 0 then
				moveDir = moveDir.Unit
				local cam = workspace.CurrentCamera
				local forward = (cam.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
				local right = (cam.CFrame.RightVector * Vector3.new(1, 0, 1)).Unit
				bv.Velocity = forward * -moveDir.Z * swimSpeedVal + right * moveDir.X * swimSpeedVal + Vector3.new(0, moveDir.Y * swimSpeedVal + bob, 0)
			else
				bv.Velocity = Vector3.new(0, -2 + bob, 0)
			end
		end)
	else
		local c = LocalPlayer.Character
		if c then
			local hrp = c:FindFirstChild("HumanoidRootPart")
			if hrp then
				local b = hrp:FindFirstChildOfClass("BodyVelocity")
				if b then b:Destroy() end
			end
			local hum = c:FindFirstChildOfClass("Humanoid")
			if hum then
				hum.HipHeight = 0
				hum:ChangeState(Enum.HumanoidStateType.Running)
			end
		end
	end
end)


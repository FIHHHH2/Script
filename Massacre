local function isAlive(player)
    local char = player.Character
    if not char then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    return humanoid.Health > 0
end
local function isVisible(targetPart)
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local ignoreList = {}
    if LocalPlayer.Character then
        table.insert(ignoreList, LocalPlayer.Character)
    end
    rayParams.FilterDescendantsInstances = ignoreList
    local result = workspace:Raycast(origin, direction, rayParams)
    if result then
        local hitChar = result.Instance:FindFirstAncestorOfClass("Model")
        if hitChar and hitChar == targetPart:FindFirstAncestorOfClass("Model") then
            return true
        end
        return false
    end
    return true
end
local function getClosestTarget()
    local closest = nil
    local closestDist = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if not isAlive(player) then continue end
            local char = player.Character
            if not char then continue end
            local targetPart = char:FindFirstChild(aimbotTargetPart) or char:FindFirstChild("Head")
            if not targetPart then continue end
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if not onScreen then continue end
            local screenPosV2 = Vector2.new(screenPos.X, screenPos.Y)
            local distFromCenter = (screenPosV2 - screenCenter).Magnitude
            if distFromCenter > aimbotFOV then continue end
            if not isVisible(targetPart) then continue end
            if distFromCenter < closestDist then
                closestDist = distFromCenter
                closest = player
            end
        end
    end
    return closest
end
local function updateAimbot()
    if fovCircle then
        fovCircle.Visible = aimbotEnabled and aimbotShowFOV
        fovCircle.Radius = aimbotFOV
        fovCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    end
    if not aimbotEnabled then
        aimbotCurrentTarget = nil
        return
    end
    local isAiming = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    if not isAiming then
        aimbotCurrentTarget = nil
        return
    end
    local target = getClosestTarget()
    aimbotCurrentTarget = target
    if target and target.Character then
        local targetPart = target.Character:FindFirstChild(aimbotTargetPart) or target.Character:FindFirstChild("Head")
        if targetPart then
            local targetPos = targetPart.Position
            local currentCF = Camera.CFrame
            local targetCF = CFrame.lookAt(currentCF.Position, targetPos)
            local smoothFactor = 1 / math.clamp(aimbotSmoothing, 1, 20)
            Camera.CFrame = currentCF:Lerp(targetCF, smoothFactor)
        end
    end
end
local Packets = require(ReplicatedStorage.Modules.Network.Packets)
local function grabAllMapItems()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local originalCF = hrp.CFrame
    
    local itemsToGrab = {}
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled then
            local path = desc:GetFullName()
            if path:find("Items") or path:find("Interactables") or desc.ObjectText == "Bandage" or desc.ObjectText == "Bear Trap" or desc.ObjectText == "Bloxy Cola" or desc.ObjectText == "Pepper Spray" or desc.ObjectText == "Riot Shield" or desc.ObjectText == "Metal Pipe" then
                table.insert(itemsToGrab, desc)
            end
        end
    end
    
    if #itemsToGrab == 0 then return end
    
    task.spawn(function()
        for _, prompt in ipairs(itemsToGrab) do
            if prompt.Parent and prompt.Enabled then
                hrp.CFrame = prompt.Parent:GetPivot()
                task.wait(0.2)
                if fireproximityprompt then
                    fireproximityprompt(prompt)
                else
                    prompt:InputHoldBegin()
                    task.wait(prompt.HoldDuration + 0.1)
                    prompt:InputHoldEnd()
                end
                task.wait(0.2)
            end
        end
        hrp.CFrame = originalCF
    end)
end
local function getAllTools()
    local tools = {}
    local toolsFolder = ReplicatedStorage:FindFirstChild("Assets")
    if toolsFolder then
        toolsFolder = toolsFolder:FindFirstChild("Tools")
    end
    if toolsFolder then
        for _, tool in ipairs(toolsFolder:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(tools, tool)
            end
        end
    end
    -- Also scan entire ReplicatedStorage for any other tools
    for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
        if desc:IsA("Tool") and desc.Parent ~= toolsFolder then
            table.insert(tools, desc)
        end
    end
    -- Check Lighting (some games hide tools here)
    pcall(function()
        for _, desc in ipairs(game:GetService("Lighting"):GetDescendants()) do
            if desc:IsA("Tool") then
                table.insert(tools, desc)
            end
        end
    end)
    return tools
end
local function giveItem(tool)
    -- Fire the server-sided changeWeapon packet with the tool's name
    -- Teleport bypass for Massacre
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local oldCF = hrp.CFrame
        hrp.CFrame = CFrame.new(-47, -23, -237)
        task.wait(0.2)
        Packets.changeWeapon:Fire(tool.Name)
        task.wait(0.3)
        hrp.CFrame = oldCF
    else
        Packets.changeWeapon:Fire(tool.Name)
    end
end
local function giveAllItems()
    local tools = getAllTools()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local oldCF = hrp.CFrame
        hrp.CFrame = CFrame.new(-47, -23, -237)
        task.wait(0.2)
        for i, tool in ipairs(tools) do
            Packets.changeWeapon:Fire(tool.Name)
            if i < #tools then
                task.wait(0.15)
            end
        end
        task.wait(0.3)
        hrp.CFrame = oldCF
    else
        for i, tool in ipairs(tools) do
            Packets.changeWeapon:Fire(tool.Name)
            if i < #tools then
                task.wait(0.15)
            end
        end
    end
end

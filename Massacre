local ragdollEnabled = false
createToggleRow(playerContainer, "Ragdoll Walk", "Ragdoll Walk", 246, false, function(state)
	ragdollEnabled = state
	local bvList = {}
	local active = false

	local function cleanup()
		active = false
		bvList = {}
		local c = LocalPlayer.Character
		if not c then return end
		for _, v in ipairs(c:GetDescendants()) do
			if v:IsA("BodyVelocity") or v:IsA("BodyGyro") then
				v:Destroy()
			end
		end
	end

	if state then
		task.spawn(function()
			while ragdollEnabled do
				task.wait(0.3)
				local c = LocalPlayer.Character
				if not c then
					if active then cleanup() end
					continue
				end
				local hum = c:FindFirstChildOfClass("Humanoid")
				local hrp = c:FindFirstChild("HumanoidRootPart")
				if not hum or not hrp then
					if active then cleanup() end
					continue
				end

				local hState = hum:GetState()
				local isRagdolled = hState == Enum.HumanoidStateType.Physics

				if isRagdolled and not active then
					active = true
					for _, v in ipairs(c:GetDescendants()) do
						if v:IsA("BasePart") then
							v.CanCollide = false
						end
					end
					for _, v in ipairs(c:GetDescendants()) do
						if v:IsA("BasePart") then
							local bv = Instance.new("BodyVelocity")
							bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
							bv.P = 1e9
							bv.Parent = v
							table.insert(bvList, bv)
							local bg = Instance.new("BodyGyro")
							bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
							bg.P = 5000
							bg.D = 100
							bg.CFrame = v.CFrame
							bg.Parent = v
							table.insert(bvList, bg)
						end
					end
				elseif not isRagdolled and active then
					cleanup()
				end

				if active then
					local cam = workspace.CurrentCamera
					local camCF = cam.CFrame
					local moveDir = Vector3.new(
						(UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0),
						0,
						(UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0)
					)
					local vel
					if moveDir.Magnitude > 0 then
						moveDir = moveDir.Unit
						local forward = (camCF.LookVector * Vector3.new(1, 0, 1)).Unit
						local right = (camCF.RightVector * Vector3.new(1, 0, 1)).Unit
						vel = forward * -moveDir.Z * walkSpeedVal + right * moveDir.X * walkSpeedVal + Vector3.new(0, -5, 0)
					else
						vel = hrp.Velocity * Vector3.new(0.85, 0, 0.85) + Vector3.new(0, -8, 0)
					end
				for _, bv in ipairs(bvList) do
					if bv and bv.Parent and bv:IsA("BodyVelocity") then
						bv.Velocity = vel
					end
				end
				end
			end
			cleanup()
		end)
	end
end)


local function advancedTeleportToSpawn()
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local humanoid = char and char:FindFirstChildOfClass("Humanoid")
	if not char or not hrp or not humanoid then return end

	local targetSpawn = nil

	-- Find spawn location
	local mapFolder = workspace:FindFirstChild("Map")
	if mapFolder then
		local lobbyFolder = mapFolder:FindFirstChild("Lobby")
		if lobbyFolder then
			local lobbySpawns = lobbyFolder:FindFirstChild("LobbySpawns")
			if lobbySpawns then
				local spawns = lobbySpawns:GetChildren()
				if #spawns > 0 then
					targetSpawn = spawns[math.random(1, #spawns)]
				end
			end
		end
	end

	if not targetSpawn and mapFolder then
		local mapInner = mapFolder:FindFirstChild("Map")
		if mapInner then
			local spawns = mapInner:FindFirstChild("Spawns")
			if spawns then
				local spawnList = spawns:GetChildren()
				if #spawnList > 0 then
					targetSpawn = spawnList[math.random(1, #spawnList)]
				end
			end
		end
	end

	if not targetSpawn then
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("SpawnLocation") then
				targetSpawn = obj
				break
			end
		end
	end

	if targetSpawn then
		task.spawn(function()
			local originalParent = char.Parent
			local targetCF = targetSpawn:IsA("Model") and targetSpawn:GetPivot() or (targetSpawn.CFrame + Vector3.new(0, 3, 0))

			local neutralZone = CFrame.new(Vector3.new(0, 500, 0))

			char.Parent = nil
			task.wait(0.02)
			hrp.CFrame = neutralZone
			task.wait(0.05)

			local parts = char:GetDescendants()
			local originalAnchors = {}
			for _, part in ipairs(parts) do
				if part:IsA("BasePart") then
					originalAnchors[part] = part.CanCollide
					part.CanCollide = false
				end
			end

			task.wait(0.02)

			for step = 1, 5 do
				local progress = step / 5
				local intermediatePos = neutralZone.Position:Lerp(targetCF.Position, progress)
				hrp.CFrame = CFrame.new(intermediatePos)
				task.wait(0.01)
			end

			hrp.CFrame = targetCF
			task.wait(0.03)

			for part, canCollide in pairs(originalAnchors) do
				if part and part.Parent then
					part.CanCollide = canCollide
				end
			end

			if humanoid then
				humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
				humanoid:ChangeState(Enum.HumanoidStateType.Landed)
				task.wait(0.02)
				humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
				humanoid:ChangeState(Enum.HumanoidStateType.Running)
			end

			task.wait(0.03)
			char.Parent = originalParent

			task.wait(0.05)
			if hrp and hrp.Parent then
				hrp.CFrame = targetCF
				if humanoid then
					humanoid:Move(Vector3.new(0.1, 0, 0), false)
					task.wait(0.01)
					humanoid:Move(Vector3.new(0, 0, 0), false)
				end
			end
		end)
	else
		warn("Could not find spawn location.")
	end
end

local function teleportToSpawn()
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	local targetSpawn = nil

	-- Method 1: Try Workspace > Map > Lobby > LobbySpawns
	local mapFolder = workspace:FindFirstChild("Map")
	if mapFolder then
		local lobbyFolder = mapFolder:FindFirstChild("Lobby")
		if lobbyFolder then
			local lobbySpawns = lobbyFolder:FindFirstChild("LobbySpawns")
			if lobbySpawns then
				local spawns = lobbySpawns:GetChildren()
				if #spawns > 0 then
					targetSpawn = spawns[math.random(1, #spawns)]
				end
			end
		end
	end

	-- Method 2: If not in lobby, try Workspace > Map > Map > Spawns
	if not targetSpawn and mapFolder then
		local mapInner = mapFolder:FindFirstChild("Map")
		if mapInner then
			local spawns = mapInner:FindFirstChild("Spawns")
			if spawns then
				local spawnList = spawns:GetChildren()
				if #spawnList > 0 then
					targetSpawn = spawnList[math.random(1, #spawnList)]
				end
			end
		end
	end

	-- Method 3: Search for SpawnLocation objects
	if not targetSpawn then
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("SpawnLocation") then
				targetSpawn = obj
				break
			end
		end
	end

	-- Method 4: Look for any part with "spawn" in name
	if not targetSpawn then
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("Part") and obj.Name:lower():find("spawn") then
				targetSpawn = obj
				break
			end
		end
	end

	if targetSpawn then
		task.spawn(function()
			local originalParent = char.Parent
			local originalCF = hrp.CFrame
			local targetCF = targetSpawn:IsA("Model") and targetSpawn:GetPivot() or (targetSpawn.CFrame + Vector3.new(0, 3, 0))

			-- Layer 1: Character Visibility
			char.Parent = nil
			task.wait(0.02)

			-- Layer 2: Sub-frame Updates
			local intermediatePos = originalCF.Position:Lerp(targetCF.Position, 0.25)
			hrp.CFrame = CFrame.new(intermediatePos)
			task.wait(0.01)

			intermediatePos = originalCF.Position:Lerp(targetCF.Position, 0.5)
			hrp.CFrame = CFrame.new(intermediatePos)
			task.wait(0.01)

			intermediatePos = originalCF.Position:Lerp(targetCF.Position, 0.75)
			hrp.CFrame = CFrame.new(intermediatePos)
			task.wait(0.01)

			-- Final position
			hrp.CFrame = targetCF
			task.wait(0.02)

			-- Layer 3: State Manipulation
			local humanoid = char:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
				humanoid:ChangeState(Enum.HumanoidStateType.Landed)
				task.wait(0.01)
				humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
			end

			-- Layer 4: Velocity Matching
			local bodyVelocity = Instance.new("BodyVelocity")
			bodyVelocity.MaxForce = Vector3.new(0, 0, 0)
			bodyVelocity.Parent = hrp
			task.wait(0.01)
			bodyVelocity:Destroy()

			-- Layer 5: Network Desync
			task.wait(0.03)
			char.Parent = originalParent

			-- Layer 6: Position Lock
			task.wait(0.05)
			if hrp and hrp.Parent then
				hrp.CFrame = targetCF
			end
		end)
	else
		warn("Could not find spawn location. Try using in lobby or round.")
	end
end


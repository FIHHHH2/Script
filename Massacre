local bgTValue = 0
local bgTBase = {}
local bgTElements = {}
local function collectBgElements()
	bgTElements = {}
	bgTBase = {}
	local function scan(inst)
		for _, c in ipairs(inst:GetChildren()) do
			if c:IsA("Frame") or c:IsA("TextButton") or c:IsA("ImageButton") or c:IsA("ScrollingFrame") then
				local bg = c.BackgroundTransparency
				if bg < 0.99 and c ~= contentFrame then
					table.insert(bgTElements, c)
					bgTBase[c] = bg
				end
			end
			scan(c)
		end
	end
	scan(screenGui)
end

local function applyBgTransparency(val)
	bgTValue = val
	if #bgTElements == 0 then collectBgElements() end
	for _, el in ipairs(bgTElements) do
		if el and el.Parent then
			local base = bgTBase[el] or 0
			el.BackgroundTransparency = base + (1 - base) * val
		end
	end
end
task.spawn(function()
	task.wait(0.3)
	collectBgElements()
end)

createSliderRow(gameContainer, "BgTransparency", "BG Transparency", 298, 0.9, 0, 0.95, 0.05, "%.2f", function(val)
	applyBgTransparency(val)
end)


		-- Reparent so LocalGunService re-registers the tool
		if tool.Parent == LocalPlayer.Character then
			tool.Parent = LocalPlayer.Backpack
		end
		local parent = tool.Parent
		tool.Parent = nil
		task.wait(0.1)
		tool.Parent = parent
	end
end

local function watchBackpackAndChar(player)
	addConnection(player.Backpack.ChildAdded:Connect(setupKnife))
	addConnection(player.CharacterAdded:Connect(function(char)
		addConnection(char.ChildAdded:Connect(setupKnife))
		for _, child in ipairs(char:GetChildren()) do
			setupKnife(child)
		end
	end))
	if player.Character then
		addConnection(player.Character.ChildAdded:Connect(setupKnife))
		for _, child in ipairs(player.Character:GetChildren()) do
			setupKnife(child)
		end
	end
	for _, child in ipairs(player.Backpack:GetChildren()) do
		setupKnife(child)
	end
end


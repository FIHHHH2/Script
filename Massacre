-- Store initial UI element references for restyling
local allUIStrokes = {}

local function collectStrokes()
	allUIStrokes = {}
	local function scan(inst)
		for _, c in ipairs(inst:GetChildren()) do
			if c:IsA("UIStroke") then
				table.insert(allUIStrokes, c)
			end
			scan(c)
		end
	end
	scan(screenGui)
end
task.spawn(collectStrokes)

local function applyLayout(idx)
	if not mainFrame or not titleBar then return end
	local lay = layoutPresets[idx]
	if not lay then return end

	-- Assign theme
	for k, v in pairs(lay) do
		if k ~= "name" and k ~= "corner" and k ~= "outlineThick" and k ~= "titleGradDark" and k ~= "titleGradLight" then
			THEME[k] = v
		end
	end

	-- Main frame
	mainFrame.BackgroundColor3 = THEME.bg
	mainCorner.CornerRadius = UDim.new(0, lay.corner)
	mainStroke.Color = THEME.borderLight
	mainStroke.Thickness = lay.outlineThick

	-- Title bar
	titleBar.BackgroundColor3 = THEME.bgSecondary
	titleCorner.CornerRadius = UDim.new(0, lay.corner)
	titleGrad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, lay.titleGradDark),
		ColorSequenceKeypoint.new(1, lay.titleGradLight),
	})
	if titleFix then titleFix.BackgroundColor3 = THEME.bgSecondary end
	titleLine.BackgroundColor3 = THEME.border
	titleLabel.TextColor3 = THEME.accentBright
	subtitleLabel.TextColor3 = THEME.accentDim
	gearBtn.BackgroundColor3 = THEME.toggleOff
	gearBtn.TextColor3 = THEME.accentDim

	-- Tab bar
	tabBar.BackgroundColor3 = THEME.bg
	tabBarLine.BackgroundColor3 = THEME.border
	activeIndicator.BackgroundColor3 = THEME.accent
	for i, btn in ipairs(tabButtons) do
		local isActive = tabContainers[i].Visible
		btn.TextColor3 = isActive and THEME.accent or THEME.textDim
	end

	-- Content containers
	for _, c in ipairs(tabContainers) do
		c.ScrollBarImageColor3 = THEME.accent
	end

	-- Footer
	if footer then
		footer.BackgroundColor3 = THEME.bgSecondary
		footer.TextColor3 = THEME.textDim
	end

	-- Update UI strokes
	task.spawn(function()

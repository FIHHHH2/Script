local function setupKnife(tool)
	if tool:IsA("Tool") and tool.Name == "Knife" and not tool:GetAttribute("NoViewmodel") then
		tool:SetAttribute("Melee", true)
		tool:SetAttribute("NoViewmodel", true)
		local script = tool:FindFirstChild("LocalScript")

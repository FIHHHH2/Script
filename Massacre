local function grabAllMapItems()
	local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local char = LocalPlayer.Character
	local originalCF = hrp.CFrame
	local originalParent = char.Parent

	local itemsToGrab = {}

	-- Search through entire workspace for proximity prompts
	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("ProximityPrompt") and desc.Enabled then
			local parent = desc.Parent
			if parent then
				local isItem = false
				local path = desc:GetFullName()

				if path:lower():find("item") or parent.Name:lower():find("item") then
					isItem = true
				elseif desc.ObjectText and (
					desc.ObjectText:lower():find("bandage") or
						desc.ObjectText:lower():find("cola") or
						desc.ObjectText:lower():find("trap") or
						desc.ObjectText:lower():find("pepper") or
						desc.ObjectText:lower():find("shield") or
						desc.ObjectText:lower():find("pipe")
					) then
					isItem = true
				end

				if isItem then
					table.insert(itemsToGrab, desc)
				end
			end
		end
	end

	if #itemsToGrab == 0 then return end

	task.spawn(function()
		for i, prompt in ipairs(itemsToGrab) do
			if prompt.Parent and prompt.Enabled then
				local targetPart = prompt.Parent:IsA("Model") and (prompt.Parent.PrimaryPart or prompt.Parent:FindFirstChildWhichIsA("BasePart")) or prompt.Parent
				if targetPart then
					local targetCF = targetPart.CFrame + Vector3.new(0, 3, 0)

					char.Parent = nil
					task.wait(0.01)

					local startPos = hrp.CFrame.Position
					local endPos = targetCF.Position
					hrp.CFrame = CFrame.new(startPos:Lerp(endPos, 0.5)) + Vector3.new(0, 3, 0)
					task.wait(0.01)

					hrp.CFrame = targetCF
					task.wait(0.01)

					char.Parent = originalParent
					task.wait(0.08)

					if fireproximityprompt then
						fireproximityprompt(prompt)
					else
						prompt:InputHoldBegin()
						task.wait(math.max(prompt.HoldDuration or pushHoldDuration, 0.2))
						prompt:InputHoldEnd()
					end
					task.wait(pushItemDelay)
				end
			end
		end

		char.Parent = nil
		task.wait(0.01)
		hrp.CFrame = originalCF
		task.wait(0.05)
		char.Parent = originalParent
	end)
end

local function getAllTools()
	local tools = {}
	local toolsFolder = ReplicatedStorage:FindFirstChild("Assets")
	if toolsFolder then
		toolsFolder = toolsFolder:FindFirstChild("Tools")
	end
	if toolsFolder then
		for _, tool in ipairs(toolsFolder:GetChildren()) do
			if tool:IsA("Tool") then
				table.insert(tools, tool)
			end
		end
	end
	-- Also scan entire ReplicatedStorage for any other tools
	for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
		if desc:IsA("Tool") and desc.Parent ~= toolsFolder then
			table.insert(tools, desc)
		end
	end
	-- Check Lighting (some games hide tools here)
	pcall(function()
		for _, desc in ipairs(game:GetService("Lighting"):GetDescendants()) do
			if desc:IsA("Tool") then
				table.insert(tools, desc)
			end
		end
	end)
	return tools
end


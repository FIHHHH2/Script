local bhopEnabled = false
local function toggleBunnyHop()
	bhopEnabled = not bhopEnabled
	if bhopEnabled then
		bhopCurrentSpeed = 50
		task.spawn(function()
			while bhopEnabled do
				task.wait()
				local c = LocalPlayer.Character
				if not c then continue end
				local hrp = c:FindFirstChild("HumanoidRootPart")
				local hum = c:FindFirstChildOfClass("Humanoid")
				if not hrp or not hum then continue end

				local onGround = hum:GetState() == Enum.HumanoidStateType.Running or hum:GetState() == Enum.HumanoidStateType.Landed
				if UserInputService:IsKeyDown(Enum.KeyCode.Space) and onGround then
					bhopCurrentSpeed = math.min(bhopCurrentSpeed + 3, bhopMaxSpeed)
					local forward = (workspace.CurrentCamera.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
					hum:ChangeState(Enum.HumanoidStateType.Jumping)
					hrp.Velocity = Vector3.new(forward.X * bhopCurrentSpeed, jumpPowerVal * 1.3, forward.Z * bhopCurrentSpeed)
				elseif not onGround then
					local vel = hrp.Velocity
					local flatSpeed = Vector3.new(vel.X, 0, vel.Z).Magnitude
					if flatSpeed < bhopCurrentSpeed then
						local forward = (workspace.CurrentCamera.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
						hrp.Velocity = Vector3.new(forward.X * bhopCurrentSpeed, vel.Y, forward.Z * bhopCurrentSpeed)
					end
				end
			end
		end)
	end
end


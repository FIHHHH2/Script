local function applyWeaponModifiers()
	for weaponName, backup in pairs(weaponConfigBackup) do
		local config = GunConfig[weaponName]
		if not config then continue end

		local isMelee = weaponName == "Knife" or weaponName == "Hunting Knife" or weaponName == "Bat"

		if isMelee then
			-- Melee Range
			if meleeModifiers.rangeEnabled then
				config.Range = meleeModifiers.rangeValue
			else
				config.Range = backup.Range or 8
			end

			-- Melee Speed (FireRate)
			if meleeModifiers.speedEnabled then
				config.FireRate = meleeModifiers.speedValue
			else
				config.FireRate = backup.FireRate or 1.0
			end

			-- Melee Auto Swing
			if meleeModifiers.allAuto then
				config.FireMode = "Auto"
			else
				config.FireMode = backup.FireMode or "Semi"
			end
		else
			-- No Spread
			if weaponModifiers.noSpread then
				config.Spread = 0
				config.AimSpread = 0
			else
				config.Spread = backup.Spread
				config.AimSpread = backup.AimSpread
			end

			-- No Recoil
			if weaponModifiers.noRecoil and config.Recoil then
				config.Recoil.Kick = Vector3.new(0, 0, 0)
				config.Recoil.Rot = Vector3.new(0, 0, 0)
				config.Recoil.CameraKick = 0
				config.AimRecoilMult = 0
			elseif backup.Recoil and config.Recoil then
				config.Recoil.Kick = backup.Recoil.Kick
				config.Recoil.Rot = backup.Recoil.Rot
				config.Recoil.CameraKick = backup.Recoil.CameraKick
				config.AimRecoilMult = backup.AimRecoilMult
			end

			-- Rapid Fire (halve fire rate)
			if weaponModifiers.rapidFire then
				config.FireRate = backup.FireRate * 0.35
			else
				config.FireRate = backup.FireRate
			end

			-- Instant Reload
			if weaponModifiers.instantReload then
				config.ReloadTime = 0.05
			else
				config.ReloadTime = backup.ReloadTime
			end

			-- Infinite Ammo (huge magazine)
			if weaponModifiers.infiniteAmmo then
				config.MagazineSize = 9999
			else
				config.MagazineSize = backup.MagazineSize
			end

			-- All Auto
			if weaponModifiers.allAuto then
				config.FireMode = "Auto"
			else
				config.FireMode = backup.FireMode
			end
		end
	end
end

local function restoreWeaponConfigs()
	for weaponName, backup in pairs(weaponConfigBackup) do
		local config = GunConfig[weaponName]
		if not config then continue end
		config.Spread = backup.Spread
		config.AimSpread = backup.AimSpread
		config.FireRate = backup.FireRate
		config.ReloadTime = backup.ReloadTime
		config.MagazineSize = backup.MagazineSize
		config.FireMode = backup.FireMode
		config.Range = backup.Range
		if config.Recoil and backup.Recoil then
			config.Recoil.Kick = backup.Recoil.Kick
			config.Recoil.Rot = backup.Recoil.Rot
			config.Recoil.CameraKick = backup.Recoil.CameraKick
		end
		config.AimRecoilMult = backup.AimRecoilMult
	end
end


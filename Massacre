			if not onScreen then continue end

			local screenPosV2 = Vector2.new(screenPos.X, screenPos.Y)
			local distFromCenter = (screenPosV2 - screenCenter).Magnitude
			if distFromCenter > silentAimFOV then continue end
			if silentAimCheckVisible and not isVisible(targetPart) then continue end

			if distFromCenter < closestDist then
				closestDist = distFromCenter
				closest = player
			end
		end
	end
	return closest
end

local function hookSilentAim()
	if silentAimHooked then return end
	local fireHitscan = Packets.fireHitscan
	if not fireHitscan or type(fireHitscan) ~= "table" then return end
	local originalFire = fireHitscan.Fire
	if not originalFire then return end
	fireHitscan.Fire = function(self, data, ...)
		if silentAimEnabled and data and data.hits and data.origin then
			local target = getSilentAimTarget()
			if target and target.Character then
				local targetPart = target.Character:FindFirstChild(silentAimTargetPart) or target.Character:FindFirstChild("Head")
				if targetPart then
					local camPos = data.origin
					local dir = (targetPart.Position - camPos).Unit
					local range = 500
					local hitPos = camPos + dir * (targetPart.Position - camPos).Magnitude
					local newHits = {}
					for _, hit in ipairs(data.hits) do
						local nhit = {
							p = hitPos,
							i = targetPart,
							n = hit.n or Vector3.new(0, 1, 0)
						}
						table.insert(newHits, nhit)
					end
					data.hits = newHits
				end
			end
		end
		return originalFire(self, data, ...)
	end
	silentAimHooked = true
end
task.spawn(hookSilentAim)


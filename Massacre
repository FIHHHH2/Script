        task.spawn(setupCharacterESP, player, char)
    end)
    addConnection(conn)
end
local function removeESP(player)
    local hl = espFolder:FindFirstChild(player.Name .. "_HL")
    if hl then hl:Destroy() end
    local bb = espFolder:FindFirstChild(player.Name .. "_BB")
    if bb then bb:Destroy() end
end
local function clearAllESP()
    espFolder:ClearAllChildren()
end
local function updateESP()
    if not espEnabled then
        clearAllESP()
        return
    end
    local localChar = LocalPlayer.Character
    local localHrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local highlight = espFolder:FindFirstChild(player.Name .. "_HL")
            local billboard = espFolder:FindFirstChild(player.Name .. "_BB")
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                if not highlight or not billboard then
                    setupCharacterESP(player, player.Character)
                    highlight = espFolder:FindFirstChild(player.Name .. "_HL")
                    billboard = espFolder:FindFirstChild(player.Name .. "_BB")
                end
            end
            if highlight then
                highlight.Enabled = true
            end
            if billboard then
                billboard.Enabled = true
                local label = billboard:FindFirstChild("Label")
                if label then
                    local distStr = ""
                    if localHrp and player.Character then
                        local targetHrp = player.Character:FindFirstChild("HumanoidRootPart")
                        if targetHrp then
                            local dist = math.floor((localHrp.Position - targetHrp.Position).Magnitude)
                            distStr = string.format(" [%d studs]", dist)
                        end
                    end
                    -- Show health
                    local healthStr = ""
                    if player.Character then
                        local hum = player.Character:FindFirstChildOfClass("Humanoid")
                        if hum then
                            healthStr = string.format(" | HP: %d", math.floor(hum.Health))
                        end
                    end
                    label.Text = player.Name .. distStr .. healthStr
                    -- Color by distance
                    if localHrp and player.Character then
                        local targetHrp = player.Character:FindFirstChild("HumanoidRootPart")
                        if targetHrp then
                            local dist = (localHrp.Position - targetHrp.Position).Magnitude
                            if dist < 50 then
                                label.TextColor3 = Color3.fromRGB(255, 50, 50)
                                highlight.FillColor = Color3.fromRGB(255, 50, 50)
                                highlight.OutlineColor = Color3.fromRGB(255, 80, 80)
                            elseif dist < 150 then
                                label.TextColor3 = Color3.fromRGB(255, 180, 50)
                                highlight.FillColor = Color3.fromRGB(255, 180, 50)
                                highlight.OutlineColor = Color3.fromRGB(255, 200, 80)
                            else
                                label.TextColor3 = Color3.fromRGB(50, 255, 120)
                                highlight.FillColor = Color3.fromRGB(50, 255, 120)
                                highlight.OutlineColor = Color3.fromRGB(80, 255, 140)
                            end
                        end
                    end
                end
            end
        end
    end
end

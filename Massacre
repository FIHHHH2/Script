local function setupCharacterESP(player, char)
	if player == LocalPlayer then return end
	
	local isKiller = false
	if player.Team and (player.Team.Name == "Killers" or player.Team.Name == "Juggernaut") then
		isKiller = true
	end

	if espIgnoreRegulars and not isKiller then
		return
	end

	local hrp = char:WaitForChild("HumanoidRootPart", 5)
	if not hrp then return end

	local highlight = espFolder:FindFirstChild(player.Name .. "_HL")
	if not highlight then
		highlight = Instance.new("Highlight")
		highlight.Name = player.Name .. "_HL"
		highlight.FillTransparency = espFillTransparency
		highlight.OutlineTransparency = espOutlineTransparency
		highlight.FillColor = Color3.fromRGB(255, 50, 80)
		highlight.OutlineColor = Color3.fromRGB(255, 100, 120)
		highlight.Parent = espFolder
	end
	highlight.Adornee = char

	local billboard = espFolder:FindFirstChild(player.Name .. "_BB")
	if not billboard then
		billboard = Instance.new("BillboardGui")
		billboard.Name = player.Name .. "_BB"
		billboard.AlwaysOnTop = true
		billboard.Size = UDim2.new(0, 220, 0, 50)
		billboard.StudsOffset = Vector3.new(0, 3.5, 0)
		billboard.Parent = espFolder

		local label = Instance.new("TextLabel")
		label.Name = "Label"
		label.BackgroundTransparency = 1
		label.Size = UDim2.new(1, 0, 1, 0)
		label.Font = Enum.Font.GothamBold
		label.TextSize = 14
		label.TextStrokeTransparency = 0
		label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		label.TextColor3 = Color3.fromRGB(255, 80, 100)
		label.Parent = billboard
	end
	billboard.Adornee = hrp
end


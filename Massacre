local origWalkSpeed = 16
local origJumpPower = 50
local char = LocalPlayer.Character
if char then
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		origWalkSpeed = hum.WalkSpeed
		origJumpPower = hum.JumpPower
	end
end

local walkSpeedVal = origWalkSpeed
local jumpPowerVal = origJumpPower
local charLoopRunning = false
local noSlowdown = false

local function startCharLoop()
	if charLoopRunning then return end
	charLoopRunning = true
	task.spawn(function()
		while charLoopRunning do
			task.wait(noSlowdown and 0.1 or 0.5)
			local c = LocalPlayer.Character
			if c then
				local hum = c:FindFirstChildOfClass("Humanoid")
				if hum then
					if noSlowdown or walkSpeedVal ~= origWalkSpeed then
						hum.WalkSpeed = walkSpeedVal
					end
					if jumpPowerVal ~= origJumpPower then
						hum.JumpPower = jumpPowerVal
					end
				end
			end
		end
	end)
end


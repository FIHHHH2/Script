local function triggerBlackout()
	-- Check if player is in a round (i.e. not in the lobby and has an active character)
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	
	local inLobby = workspace:FindFirstChild("Map")
	if inLobby then
		inLobby = inLobby:FindFirstChild("Lobby")
	end
	
	-- Only run breaker switch autocomplete if we are in-game (not in lobby)
	if hrp and not inLobby then
		-- Search for the breaker switch ProximityPrompt
		local breakerPrompt = nil
		local interactables = workspace:FindFirstChild("Map")
		if interactables then
			interactables = interactables:FindFirstChild("Map")
			if interactables then
				interactables = interactables:FindFirstChild("Interactables")
			end
		end
		
		if interactables then
			for _, model in ipairs(interactables:GetChildren()) do
				local prompt = model:FindFirstChildOfClass("ProximityPrompt")
				if prompt and (prompt.ActionText == "Disable lights" or prompt.ObjectText == "Breaker" or prompt.ActionText:lower():find("light")) then
					breakerPrompt = prompt
					break
				end
			end
		end
		
		if breakerPrompt and breakerPrompt.Enabled then
			task.spawn(function()
				local originalCF = hrp.CFrame

				local originalParent = char.Parent
				char.Parent = nil
				task.wait(0.1)
				hrp.CFrame = breakerPrompt.Parent:GetPivot()
				task.wait(0.15)
				char.Parent = originalParent
				task.wait(0.1)

				if fireproximityprompt then
					fireproximityprompt(breakerPrompt)
				else
					breakerPrompt:InputHoldBegin()
					task.wait(breakerPrompt.HoldDuration + 0.2)
					breakerPrompt:InputHoldEnd()
				end
				task.wait(0.2)

				char.Parent = nil
				task.wait(0.1)
				hrp.CFrame = originalCF
				task.wait(0.15)
				char.Parent = originalParent
			end)
			return
		end
	end
	
	-- Fallback: Local Client-Side Blackout if not in game or prompt not found
	local blackoutFolder = game:GetService("Lighting"):FindFirstChild("Blackout")
	local blackoutAtm = blackoutFolder and blackoutFolder:FindFirstChild("BlackOutAtm")

	local powerOutageSound = game:GetService("SoundService"):FindFirstChild("Power Outage")
	if powerOutageSound then
		powerOutageSound:Play()
	end

	if blackoutAtm then
		local currentAtm = game:GetService("Lighting"):FindFirstChildOfClass("Atmosphere")
		if currentAtm and currentAtm.Name ~= "BlackOutAtm" then
			currentAtm:Destroy()
		end
		if not game:GetService("Lighting"):FindFirstChild("BlackOutAtm") then
			local clone = blackoutAtm:Clone()
			clone.Parent = game:GetService("Lighting")
			clone.Density = 0.95
		end
	end

	game:GetService("Lighting").OutdoorAmbient = Color3.fromRGB(15, 15, 15)
	game:GetService("Lighting").Ambient = Color3.fromRGB(15, 15, 15)
	game:GetService("Lighting").Brightness = 0
end


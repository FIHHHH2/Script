local UserInputService = game:GetService("UserInputService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")

local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

-- Wait for character to load
local PlayerCharacter = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

local Bindings = {
    ESP = { Key = Enum.KeyCode.Z, Boolean = false },
    AimLock = { Key = Enum.KeyCode.X, Boolean = false },
    InfJump = { Key = Enum.KeyCode.C, Boolean = false },
}

-- Helper Functions
local function IsSameTeam(Player1, Player2)
    if not Player1.Neutral or not Player2.Neutral then
        return Player1.Team and Player2.Team and Player1.Team == Player2.Team
    end
    return false
end

local function IsVisible(Origin, Target, IgnoreList)
    local RaycastParams = RaycastParams.new()
    RaycastParams.FilterDescendantsInstances = IgnoreList
    RaycastParams.FilterType = Enum.RaycastFilterType.Blacklist

    local Direction = (Target - Origin).Unit
    local Distance = (Target - Origin).Magnitude
    local RaycastResult = workspace:Raycast(Origin, Direction * Distance, RaycastParams)

    return not RaycastResult
end

-- Infinite Jump
local function PlatformFallOff(BasePart)
    task.spawn(function()
        while task.wait() and Bindings.InfJump.Boolean do
            BasePart.Position -= Vector3.new(0, 0.45, 0)
        end
    end)
end

local function InfiniteJump()
    if not Bindings.InfJump.Boolean then return end

    local RightFoot = PlayerCharacter:FindFirstChild("RightFoot") or PlayerCharacter:FindFirstChild("Right Leg")
    if not RightFoot then return end

    local NewPlatform = Instance.new("Part", workspace)
    NewPlatform.Anchored = true
    NewPlatform.Transparency = 0.85
    NewPlatform.Size = Vector3.new(3, 0.5, 3)
    NewPlatform.CanCollide = true

    local FootPosition = RightFoot.Position - Vector3.new(0, RightFoot.Size.Y / 2, 0)
    NewPlatform.Position = FootPosition

    PlatformFallOff(NewPlatform)
    Debris:AddItem(NewPlatform, 5)
end

-- ESP

local function ApplyHighlight(character)
    local Humanoid = character:FindFirstChild("Humanoid")
    if not Humanoid or Humanoid.Health <= 0 then return end
    if character:FindFirstChild("Highlight") then return end

    local highlight = Instance.new("Highlight")
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.FillColor = Color3.fromRGB(7, 71, 127)
    highlight.OutlineColor = Color3.fromRGB(255, 247, 0)
    highlight.Enabled = Bindings.ESP.Boolean
    highlight.Parent = character
end

local function ToggleHighlights()
    for _, player in ipairs(Players:GetPlayers()) do
        local character = player.Character
        if character then
            local Humanoid = character:FindFirstChild("Humanoid")
            if not Humanoid or Humanoid.Health <= 0 then continue end

            local highlight = character:FindFirstChild("Highlight")
            if highlight then
                highlight.Enabled = Bindings.ESP.Boolean
            else
                ApplyHighlight(character)
            end
        end
    end
end

-- Apply ESP to existing and new players
for _, player in ipairs(Players:GetPlayers()) do
    if player.Character then
        local Humanoid = player.Character:FindFirstChild("Humanoid")
        if Humanoid and Humanoid.Health > 0 then
            ApplyHighlight(player.Character)
        end
    end
    player.CharacterAdded:Connect(function(character)
        local Humanoid = character:FindFirstChild("Humanoid")
        if Humanoid and Humanoid.Health > 0 then
            ApplyHighlight(character)
            ToggleHighlights()
        end
    end)
end

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(character)
        local Humanoid = character:FindFirstChild("Humanoid")
        if Humanoid and Humanoid.Health > 0 then
            ApplyHighlight(character)
            ToggleHighlights()
        end
    end)
end)

-- AimLock
RunService.Heartbeat:Connect(function()
    if not Bindings.AimLock.Boolean then return end

    local LocalCharacter = LocalPlayer.Character
    if not LocalCharacter then return end

    local LocalRootPart = LocalCharacter:FindFirstChild("HumanoidRootPart") or LocalCharacter:FindFirstChild("Torso")
    if not LocalRootPart then return end

    local PlayersTable = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local Humanoid = character:FindFirstChild("Humanoid")
            local Head = character:FindFirstChild("Head")

            -- Skip if the player is dead (Health <= 0) or has no Humanoid
            if not Humanoid or Humanoid.Health <= 0 then continue end

            if Head and not IsSameTeam(LocalPlayer, player) then
                local IgnoreList = {LocalCharacter, character}
                if IsVisible(LocalRootPart.Position, Head.Position, IgnoreList) then
                    PlayersTable[character] = Head.CFrame
                end
            end
        end
    end

    -- Rest of the AimLock logic remains the same
    local ClosestCFrame = nil
    local ShortestDistance = math.huge

    for character, cframe in PlayersTable do
        local distance = (LocalRootPart.Position - cframe.Position).Magnitude
        if distance < ShortestDistance then
            ShortestDistance = distance
            ClosestCFrame = cframe
        end
    end

    if ClosestCFrame then
        local Camera = workspace.CurrentCamera
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, ClosestCFrame.Position)
    end
end)
-- Input Handling
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == Bindings.InfJump.Key then
        Bindings.InfJump.Boolean = not Bindings.InfJump.Boolean
        print("Infinite Jump:", Bindings.InfJump.Boolean)
    elseif input.KeyCode == Bindings.ESP.Key then
        Bindings.ESP.Boolean = not Bindings.ESP.Boolean
        ToggleHighlights()
        print("ESP:", Bindings.ESP.Boolean)
    elseif input.KeyCode == Bindings.AimLock.Key then
        Bindings.AimLock.Boolean = not Bindings.AimLock.Boolean
        print("AimLock:", Bindings.AimLock.Boolean)
    elseif input.KeyCode == Enum.KeyCode.Space and Bindings.InfJump.Boolean then
        InfiniteJump()
    end
end)

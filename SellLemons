-- Helper function to make toggle buttons
local function makeToggleButton(name, flagName, layoutOrder)
    local Button = Instance.new("TextButton")
    Button.Name = name .. "Toggle"
    Button.Size = UDim2.new(1, 0, 0, 45)
    Button.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    Button.Text = name .. ": OFF"
    Button.TextColor3 = Color3.fromRGB(180, 180, 190)
    Button.TextSize = 13
    Button.Font = Enum.Font.GothamSemibold
    Button.LayoutOrder = layoutOrder
    Button.Parent = Container
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 8)
    Corner.Parent = Button
    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Color3.fromRGB(55, 55, 65)
    Stroke.Thickness = 1
    Stroke.Parent = Button
    Button.MouseButton1Click:Connect(function()
        _G_Flags[flagName] = not _G_Flags[flagName]
        if _G_Flags[flagName] then
            Button.BackgroundColor3 = Color3.fromRGB(40, 100, 50)
            Button.Text = name .. ": ON"
            Button.TextColor3 = Color3.fromRGB(255, 255, 255)
            Stroke.Color = Color3.fromRGB(80, 180, 100)
        else
            Button.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
            Button.Text = name .. ": OFF"
            Button.TextColor3 = Color3.fromRGB(180, 180, 190)
            Stroke.Color = Color3.fromRGB(55, 55, 65)
        end
    end)
end

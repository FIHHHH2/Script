-- Background loop for Auto Farm (Pressing)
task.spawn(function()
    while ScreenGui.Parent do
        task.wait(0.2)
        if _G_Flags.AutoFarm then
            local earners = localTycoon:GetEntityDescendants()
            local count = 0
            for _, ent in ipairs(earners) do
                if ent:IsA(ClientTycoonEarner) and ent:IsEnabled() then
                    count = count + 1
                    task.spawn(function()
                        pcall(function()
                            ent:WakeAsync()
                        end)
                    end)
                end
            end
            InfoLabel.Text = "Autofarming " .. tostring(count) .. " earners..."
        elseif not _G_Flags.AutoUpgrade and not _G_Flags.AutoBuy then
            InfoLabel.Text = "Status: Idle"
        end
    end
end)
-- Background loop for Auto Upgrade
task.spawn(function()
    while ScreenGui.Parent do
        task.wait(0.5)
        if _G_Flags.AutoUpgrade then
            local balances = localTycoon:GetComponent(ClientTycoonBalances)
            local currentCash = balances:GetCash()
            local earners = localTycoon:GetEntityDescendants()
            
            for _, ent in ipairs(earners) do
                if ent:IsA(ClientTycoonEarner) and ent:IsEnabled() then
                    local upgradeInfo = ent:GetNextUpgradeInfo()
                    if upgradeInfo and not upgradeInfo.Max and upgradeInfo.Price <= currentCash then
                        task.spawn(function()
                            pcall(function()
                                ent:Upgrade(upgradeInfo.Count, false)
                            end)
                        end)
                    end
                end
            end
        end
    end
end)
-- Background loop for Auto Buy
task.spawn(function()
    while ScreenGui.Parent do
        task.wait(0.5)
        if _G_Flags.AutoBuy then
            local balances = localTycoon:GetComponent(ClientTycoonBalances)
            local currentCash = balances:GetCash()
            local purchases = localTycoon:GetEntityDescendants()
            
            for _, ent in ipairs(purchases) do
                if ent:IsA(ClientTycoonPurchase) and ent:IsEnabled() and not ent.Instance:GetAttribute("Purchased") then
                    local price = ent:GetPrice()
                    if price and price <= currentCash and ent.Instance:GetAttribute("Shown") then
                        task.spawn(function()
                            pcall(function()
                                ent:TryPurchaseAsync(false)
                            end)
                        end)
                    end
                end
            end
        end
    end
end)
-- Phone Offers Listener
local phoneOffers = localTycoon:GetComponent(ClientTycoonPhoneOffers)
if phoneOffers then
    local function autoAccept()
        if _G_Flags.AutoPhone then
            task.wait(0.5) -- Small human-like delay
            pcall(function()
                if phoneOffers:GetCurrentOffer() then
                    phoneOffers:AcceptOffer()
                    InfoLabel.Text = "Status: Accepted phone offer!"
                end
            end)
        end
    end
    ScreenGui.AncestryChanged:Connect(function()
        if not ScreenGui.Parent then
            -- Clean up connections if UI destroyed
        end
    end)
    phoneOffers.OfferStarted:Connect(autoAccept)
    phoneOffers.OfferUpdated:Connect(autoAccept)
end

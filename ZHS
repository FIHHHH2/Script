    -- ============================================================
    -- SILENT AIMBOT
    -- ============================================================
    local function getClosestTarget()
        local closestDist = Config.AimbotFOV
        local closestPlayer = nil
        local closestPart = nil
        local mousePos = Mouse.Hit.p

        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if Config.AimbotTeamCheck then
                -- Check if same team (using BodyEffects or other indicators)
                local char = player.Character
                if char then
                    local be = char:FindFirstChild("BodyEffects")
                    if be then
                        -- Skip if same team (check via some game-specific method)
                    end
                end
            end

            local char = player.Character
            if not char then continue end
            local humanoid = char:FindFirstChild("Humanoid")
            if not humanoid or humanoid.Health <= 0 then continue end

            local targetPart = char:FindFirstChild(Config.AimbotTargetPart)
            if not targetPart then continue end

            -- Visibility check
            if Config.AimbotVisibleCheck then
                local origin = Camera.CFrame.p
                local direction = (targetPart.Position - origin).unit
                local ray = Ray.new(origin, direction * 500)
                local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character, workspace:FindFirstChild("Ignored") or workspace})
                if hit then
                    local hitParent = hit:IsDescendantOf(char)
                    if not hitParent then
                        -- Check if the hit is close enough to the target
                        if (pos - targetPart.Position).magnitude > 5 then
                            continue
                        end
                    end
                end
            end

            -- Screen position check for FOV
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if not onScreen then continue end

            local mousePos2D = Vector2.new(Mouse.X, Mouse.Y)
            local targetPos2D = Vector2.new(screenPos.X, screenPos.Y)
            local dist = (targetPos2D - mousePos2D).magnitude

            if dist < closestDist then
                closestDist = dist
                closestPlayer = player
                closestPart = targetPart
            end
        end

        return closestPlayer, closestPart
    end

    local function setupSilentAimbot()
        if not RemoteFunction then return end

        -- OnClientInvoke is write-only, we can't read the original.
        -- We just set our own handler that calls the game's internal handler
        -- by returning nil for non-aimbot requests (which falls through).
        RemoteFunction.OnClientInvoke = function(...)
            local args = {...}
            local requestType = args[1]

            if Config.SilentAim and requestType == "Aim" then
                local target, targetPart = getClosestTarget()
                if target and targetPart then
                    local origin = args[2] -- gun origin
                    if origin then
                        local direction = (targetPart.Position - origin).unit
                        return direction
                    end
                end
            end

            if Config.SilentAim and requestType == "MOUSEPOS" then
                local target, targetPart = getClosestTarget()
                if target and targetPart then
                    return targetPart.Position
                end
            end

            -- Return nil for non-aimbot requests so the game's default handler runs
            return nil
        end

        AimbotHooked = true
    end

    -- ============================================================
    -- ESP
    -- ============================================================
    local function createESP(player)
        if ESPObjects[player] then return end

        local esp = {}
        ESPObjects[player] = esp

        -- Highlight box
        local highlight = Instance.new("Highlight")
        highlight.Name = "ZeeESP"
        highlight.FillTransparency = 0.7
        highlight.OutlineTransparency = 0.3
        highlight.FillColor = Color3.fromRGB(255, 255, 255)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Adornee = player.Character
        highlight.Parent = CoreGui

        esp.Highlight = highlight

        -- Billboard GUI for text
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "ZeeESPText"
        billboard.Size = UDim2.new(0, 200, 0, 60)
        billboard.AlwaysOnTop = true
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.Adornee = player.Character and player.Character:FindFirstChild("Head")
        billboard.Parent = CoreGui

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, 0, 0, 20)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = player.Name
        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        nameLabel.TextSize = 14
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextStrokeTransparency = 0.5
        nameLabel.Parent = billboard

        local distLabel = Instance.new("TextLabel")
        distLabel.Size = UDim2.new(1, 0, 0, 18)
        distLabel.Position = UDim2.new(0, 0, 0, 20)
        distLabel.BackgroundTransparency = 1
        distLabel.Text = ""
        distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        distLabel.TextSize = 12
        distLabel.Font = Enum.Font.Gotham
        distLabel.TextStrokeTransparency = 0.5
        distLabel.Parent = billboard

        local healthLabel = Instance.new("TextLabel")
        healthLabel.Size = UDim2.new(1, 0, 0, 18)
        healthLabel.Position = UDim2.new(0, 0, 0, 38)
        healthLabel.BackgroundTransparency = 1
        healthLabel.Text = ""
        healthLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        healthLabel.TextSize = 12
        healthLabel.Font = Enum.Font.Gotham
        healthLabel.TextStrokeTransparency = 0.5
        healthLabel.Parent = billboard

        esp.Billboard = billboard
        esp.NameLabel = nameLabel
        esp.DistLabel = distLabel
        esp.HealthLabel = healthLabel

        -- Update connection
        local conn
        conn = RunService.RenderStepped:Connect(function()
            if not Config.ESPEnabled or not player or not player.Parent then
                if conn then conn:Disconnect() end
                destroyESP(player)
                return
            end

            local char = player.Character
            if not char then
                highlight.Adornee = nil
                billboard.Adornee = nil
                return
            end

            local humanoid = char:FindFirstChild("Humanoid")
            if not humanoid or humanoid.Health <= 0 then
                highlight.Visible = false
                billboard.Enabled = false
                return
            end

            highlight.Visible = true
            highlight.Adornee = char

            -- Team color
            if Config.ESPTeamColor then
                local teamColor = Color3.fromRGB(255, 80, 80) -- Default enemy red
                -- Try to determine team
                local be = char:FindFirstChild("BodyEffects")
                if be then
                    local officer = player:FindFirstChild("DataFolder") and player.DataFolder:FindFirstChild("Officer")
                    if officer and officer.Value > 0 then
                        teamColor = Color3.fromRGB(80, 80, 255) -- Police blue
                    end
                end
                highlight.FillColor = teamColor
                highlight.OutlineColor = teamColor
            else
                highlight.FillColor = Config.ESPBoxColor
                highlight.OutlineColor = Config.ESPBoxColor
            end

            -- Billboard
            local head = char:FindFirstChild("Head")
            if head then
                billboard.Adornee = head
                billboard.Enabled = true
            else
                billboard.Enabled = false
            end

            -- Name
            nameLabel.Visible = Config.ESPShowName
            nameLabel.Text = player.Name

            -- Distance
            if Config.ESPShowDistance then
                local dist = (Camera.CFrame.p - (head and head.Position or char.PrimaryPart and char.PrimaryPart.Position or Vector3.new())).magnitude
                distLabel.Visible = true
                distLabel.Text = math.floor(dist) .. " studs"
            else
                distLabel.Visible = false
            end

            -- Health
            if Config.ESPShowHealth then
                healthLabel.Visible = true
                local health = math.floor(humanoid.Health)
                local maxHealth = math.floor(humanoid.MaxHealth)
                healthLabel.Text = health .. "/" .. maxHealth .. " HP"
                if health > 60 then
                    healthLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                elseif health > 30 then
                    healthLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
                else
                    healthLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                end
            else
                healthLabel.Visible = false
            end
        end)

        ESPConnections[player] = conn
    end

    local function destroyESP(player)
        local esp = ESPObjects[player]
        if esp then
            if esp.Highlight then esp.Highlight:Destroy() end
            if esp.Billboard then esp.Billboard:Destroy() end
            ESPObjects[player] = nil
        end
        local conn = ESPConnections[player]
        if conn then
            conn:Disconnect()
            ESPConnections[player] = nil
        end
    end

    local function setupESP()
        -- ESP for existing players
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                createESP(player)
            end
        end

        -- ESP for new players
        Players.PlayerAdded:Connect(function(player)
            player.CharacterAdded:Connect(function()
                if Config.ESPEnabled then
                    createESP(player)
                end
            end)
        end)

        Players.PlayerRemoving:Connect(function(player)
            destroyESP(player)
        end)
    end

    -- ============================================================
    -- AUTO STOMP
    -- ============================================================
    local function setupAutoStomp()
        local stompCooldown = false

        RunService.Heartbeat:Connect(function()
            if not Config.AutoStomp then return end
            if stompCooldown then return end

            local char = getCharacter()
            local be = char:FindFirstChild("BodyEffects")
            if not be then return end

            -- Check if we can stomp (not attacking, not KO'd)
            local canStomp = be:FindFirstChild("Attacking") and not be.Attacking.Value
                and be:FindFirstChild("K.O") and not be["K.O"].Value

            if not canStomp then return end

            -- Find nearby KO'd players
            for _, player in ipairs(Players:GetPlayers()) do
                if player == LocalPlayer then continue end
                local targetChar = player.Character
                if not targetChar then continue end

                local targetBE = targetChar:FindFirstChild("BodyEffects")
                if not targetBE then continue end

                local isKO = targetBE:FindFirstChild("K.O") and targetBE["K.O"].Value
                if not isKO then continue end

                local rootPart = char:FindFirstChild("HumanoidRootPart")
                local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
                if not rootPart or not targetRoot then continue end

                local dist = (rootPart.Position - targetRoot.Position).magnitude
                if dist <= Config.AutoStompRange then
                    -- Fire stomp remote
                    if MainGameEvent then
                        stompCooldown = true
                        MainGameEvent:FireServer("Stomp")
                        task.wait(0.8)
                        stompCooldown = false
                    end
                    break
                end
            end
        end)
    end

    -- ============================================================
    -- FULL AUTO WEAPONS
    -- ============================================================
    -- Makes semi-auto guns fire continuously while holding mouse button 1
    local function setupFullAuto()
        local isHolding = false
        local autoThread = nil

        UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                isHolding = true
                if Config.FullAuto then
                    autoThread = task.spawn(function()
                        while isHolding and Config.FullAuto do
                            -- Fire the shoot remote
                            if MainGameEvent then
                                pcall(function()
                                    MainGameEvent:FireServer("ShootButton")
                                end)
                            end
                            task.wait(Config.FullAutoDelay)
                        end
                    end)
                end
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                isHolding = false
            end
        end)

        -- Monitor toggle changes in a separate thread
        task.spawn(function()
            local oldFullAuto = Config.FullAuto
            while task.wait(0.5) do
                if Config.FullAuto ~= oldFullAuto then
                    oldFullAuto = Config.FullAuto
                    if not Config.FullAuto then
                        isHolding = false
                    elseif isHolding then
                        autoThread = task.spawn(function()
                            while isHolding and Config.FullAuto do
                                if MainGameEvent then
                                    pcall(function()
                                        MainGameEvent:FireServer("ShootButton")
                                    end)
                                end
                                task.wait(Config.FullAutoDelay)
                            end
                        end)
                    end
                end
            end
        end)
    end

    -- ============================================================
    -- MAIN LOOP
    -- ============================================================
    local function mainLoop()
        -- Apply weapon mods continuously
        RunService.RenderStepped:Connect(function()
            -- WalkSpeed / JumpPower override
            local char = getCharacter()
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.WalkSpeed = Config.WalkSpeed
                humanoid.JumpPower = Config.JumpPower
            end

            -- Weapon mods
            applyWeaponMods()
        end)
    end

    -- ============================================================
    -- INITIALIZATION
    -- ============================================================
    local function init()
        -- Create UI
        local gui = UI:Create()

        -- Setup features
        setupSpeedBypass()
        setupInfiniteJump()
        setupNoRecoil()
        setupSilentAimbot()
        setupESP()
        setupAutoStomp()
        task.spawn(setupFullAuto)

        -- Start main loop
        mainLoop()

        -- Notification
        StarterGui:SetCore("SendNotification", {
            Title = "Zee [MACRO] Cheat",
            Text = "Loaded successfully! Press RightShift to toggle menu visibility.",
            Duration = 3
        })

        -- Toggle menu visibility with RightShift
        local menuVisible = true
        UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.KeyCode == Enum.KeyCode.RightShift then
                menuVisible = not menuVisible
                gui.Enabled = menuVisible
            end
        end)

        -- Cleanup on character death
        LocalPlayer.CharacterAdded:Connect(function()
            task.wait(1)
            -- Re-setup features that depend on character
            setupSpeedBypass()
        end)
    end

    -- Run
    local success, err = pcall(init)
    if not success then
        warn("Zee Cheat Error: " .. tostring(err))
        StarterGui:SetCore("SendNotification", {
            Title = "Zee [MACRO] Cheat",
            Text = "Error: " .. tostring(err),
            Duration = 5
        })
    end

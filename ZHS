    local function applyWeaponMods()
        local tool = getEquippedTool()
        if not tool then return end

        -- Infinite Ammo
        if Config.InfiniteAmmo then
            local ammo = tool:FindFirstChild("Ammo")
            if ammo and ammo:IsA("IntValue") then
                ammo.Value = 999
            end
        end

        -- Rapid Fire
        if Config.RapidFire then
            local cooldown = tool:FindFirstChild("ShootingCooldown")
            if cooldown and cooldown:IsA("NumberValue") then
                cooldown.Value = 0
            end
        end

        -- Infinite Range
        if Config.InfiniteRange then
            local range = tool:FindFirstChild("Range")
            if range and range:IsA("NumberValue") then
                range.Value = 99999
            end
        end
    end


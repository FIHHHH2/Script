-- ============ UTILITY FUNCTIONS ============
local function getCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end
local function getHumanoid()
    local char = getCharacter()
    return char and char:FindFirstChildOfClass("Humanoid")
end
local function getRootPart()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end
local function getMonster()
    for _, child in pairs(Workspace:GetChildren()) do
        if child:FindFirstChild("DogServer") or child.Name == "locust" then
            return child
        end
    end
    local monsters = Workspace:FindFirstChild("ShopBackground")
    if monsters then
        local mFolder = monsters:FindFirstChild("Monsters")
        if mFolder then
            for _, m in pairs(mFolder:GetChildren()) do
                if m:IsA("Model") then return m end
            end
        end
    end
    return nil
end
local function getAllPlayers()
    local players = {}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then table.insert(players, player) end
    end
    return players
end
local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title or "Lurking Giants",
            Text = text or "",
            Duration = duration or 3
        })
    end)
end
local function disconnectKey(key)
    if CheatState._connections[key] then
        CheatState._connections[key]:Disconnect()
        CheatState._connections[key] = nil
    end
end
local function getFlashlightTool(character)
    if not character then return nil end
    local tool = character:FindFirstChild("Flashlight")
    if not tool then
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then tool = bp:FindFirstChild("Flashlight") end
    end
    return tool
end
local function getLanternTool(character)
    if not character then return nil end
    local tool = character:FindFirstChild("Lantern")
    if not tool then
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then tool = bp:FindFirstChild("Lantern") end
    end
    return tool
end

LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1)
    -- Speed hack
    if CheatState.SpeedHack then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = CheatState.SpeedValue end
    end
    -- Giant speed
    if CheatState.GiantSpeed then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = CheatState.GiantSpeedValue end
    end
    -- Player ESP
    if CheatState.PlayerESP then
        clearESP()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then createESP(player) end
        end
    end
    -- Fullbright
    if CheatState.Fullbright then
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.FogEnd = 100000
        Lighting.GlobalShadows = false
    end
    -- Jump boost
    if CheatState.JumpBoost then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            if hum.UseJumpPower then
                hum.JumpPower = 100
            else
                hum.JumpHeight = 20
            end
        end
    end
    -- Flashlight range (re-apply after respawn, will pick up new tool)
    if CheatState.FlashlightRange then
        task.wait(2) -- Wait for tools to be given
        -- The heartbeat loop will automatically apply to new tools
    end
end)

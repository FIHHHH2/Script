createToggle(visualPage, "Player ESP", "PlayerESP", function(on)
    if on then
        clearESP()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then createESP(player) end
        end
        disconnectKey("ESPUpdate")
        CheatState._connections["ESPUpdate"] = RunService.Heartbeat:Connect(function()
            if CheatState.PlayerESP then
                -- Rainbow cycling
                if CheatState.ESPRainbow then
                    CheatState._rainbowHue = (CheatState._rainbowHue + 0.005) % 1
                end
                local myRoot = getRootPart()
                for _, obj in pairs(CheatState._espObjects) do
                    pcall(function()
                        if obj.player and obj.player.Character and obj.player.Character:FindFirstChild("HumanoidRootPart") and myRoot then
                            local dist = math.floor((obj.player.Character.HumanoidRootPart.Position - myRoot.Position).Magnitude)
                            -- Distance filter
                            if dist > CheatState.ESPMaxDist then
                                if obj.highlight then obj.highlight.Enabled = false end
                                if obj.billboard then obj.billboard.Enabled = false end
                            else
                                if obj.highlight then
                                    obj.highlight.Enabled = true
                                    obj.highlight.FillColor = CheatState.ESPRainbow and Color3.fromHSV(CheatState._rainbowHue, 1, 1) or CheatState.ESPPlayerColor
                                    obj.highlight.FillTransparency = CheatState.ESPPlayerFill
                                    obj.highlight.OutlineTransparency = CheatState.ESPPlayerOutline
                                end
                                if obj.billboard then obj.billboard.Enabled = true end
                            end
                            -- Distance label
                            if obj.distLabel and obj.distLabel.Parent then
                                obj.distLabel.Text = dist .. " studs"
                                obj.distLabel.TextColor3 = CheatState.ESPDistColor
                                obj.distLabel.TextSize = CheatState.ESPTextSize - 2
                                obj.distLabel.Visible = CheatState.ESPShowDist
                            end
                            -- Name label
                            if obj.nameLabel and obj.nameLabel.Parent then
                                obj.nameLabel.Visible = CheatState.ESPShowNames
                                obj.nameLabel.TextSize = CheatState.ESPTextSize
                            end
                            -- Health bar
                            if obj.healthBg and obj.healthBg.Parent then
                                obj.healthBg.Visible = CheatState.ESPShowHealth
                                local hum = obj.player.Character:FindFirstChildOfClass("Humanoid")
                                if hum and obj.healthFill then
                                    local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                                    obj.healthFill.Size = UDim2.new(pct, 0, 1, 0)
                                    -- Color: green->yellow->red
                                    obj.healthFill.BackgroundColor3 = Color3.fromHSV(pct * 0.33, 1, 1)
                                end
                            end
                        end
                    end)
                end
            end
        end)
        disconnectKey("ESPAdded")
        CheatState._connections["ESPAdded"] = Players.PlayerAdded:Connect(function(player)
            if CheatState.PlayerESP then
                player.CharacterAdded:Connect(function() task.wait(1) createESP(player) end)
            end
        end)
        -- Re-create ESP when players respawn
        disconnectKey("ESPCharAdded")
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                player.CharacterAdded:Connect(function()
                    if CheatState.PlayerESP then
                        task.wait(1)
                        -- Remove old ESP for this player
                        for i = #CheatState._espObjects, 1, -1 do
                            local obj = CheatState._espObjects[i]
                            if obj.player == player then
                                pcall(function() if obj.highlight then obj.highlight:Destroy() end end)
                                pcall(function() if obj.billboard then obj.billboard:Destroy() end end)
                                table.remove(CheatState._espObjects, i)
                            end
                        end
                        createESP(player)
                    end
                end)
            end
        end
    else
        clearESP()
        disconnectKey("ESPUpdate")
        disconnectKey("ESPAdded")
    end
    notify("Player ESP", on and "ON" or "OFF")
end)

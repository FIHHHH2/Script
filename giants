createSectionLabel(serverPage, "ANTI-CHEAT BYPASS")
createToggle(serverPage, "Block Anti-Cheat (Detect Remote)", "SSAntiCheat", function(on)
    if on then
        disconnectKey("SSAntiCheat")
        -- Method 1: Disconnect all existing connections on Detect
        pcall(function()
            local detect = Remotes:FindFirstChild("Detect")
            if detect then
                -- Try to hook/block using executor features
                if hookfunction then
                    -- Advanced: Hook the remote's FireServer
                    local oldFire = detect.FireServer
                    hookfunction(detect.FireServer, function(...)
                        if CheatState.SSAntiCheat then
                            return nil -- Block
                        end
                        return oldFire(...)
                    end)
                    notify("Anti-Cheat", "Detect remote hooked!")
                end
            end
        end)
        -- Method 2: Continuously block via connection intercept
        CheatState._connections["SSAntiCheat"] = RunService.Heartbeat:Connect(function()
            if CheatState.SSAntiCheat then
                pcall(function()
                    local detect = Remotes:FindFirstChild("Detect")
                    if detect then
                        -- Block by replacing with dummy
                        -- Some executors support getconnections
                        if getconnections then
                            for _, conn in pairs(getconnections(detect.OnClientEvent)) do
                                pcall(function() conn:Disable() end)
                            end
                        end
                    end
                end)
            end
        end)
        notify("Anti-Cheat", "ON - Detect remote blocked!")
    else
        disconnectKey("SSAntiCheat")
        -- Re-enable connections
        pcall(function()
            local detect = Remotes:FindFirstChild("Detect")
            if detect and getconnections then
                for _, conn in pairs(getconnections(detect.OnClientEvent)) do
                    pcall(function() conn:Enable() end)
                end
            end
        end)
        notify("Anti-Cheat", "OFF - Protections re-enabled")
    end
end)

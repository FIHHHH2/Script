local CachedSilentTarget = nil
local lastCoinCollect = 0
local lastItemESPUpdate = 0

track(RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    
    -- 1. Apply WalkSpeed & JumpPower
    if humanoid then
        if Config.WalkSpeedEnabled then
            humanoid.WalkSpeed = Config.WalkSpeedValue
        end
        if Config.JumpPowerEnabled then
            humanoid.UseJumpPower = true
            humanoid.JumpPower = Config.JumpPowerValue
        end
    end
    
    -- 2. FOV adjustment
    if Config.FOVEnabled then
        Camera.FieldOfView = Config.FOVValue
    end
    
    -- 3. Camera Aimbot
    local target = GetClosestTarget()
    if Config.AimbotEnabled and target and target.Character then
        local aimPart = target.Character:FindFirstChild(Config.AimbotPart) or target.Character:FindFirstChild("Head")
        if aimPart then
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, aimPart.Position)
        end
    end
    
    -- Cache silent aim target
    if Config.SilentAimEnabled and target and target.Character then
        CachedSilentTarget = target.Character:FindFirstChild(Config.AimbotPart) or target.Character:FindFirstChild("Head")
    else
        CachedSilentTarget = nil
    end
    
    -- 4. Troll Features (Follow, Orbit, Fling, Stalk)
    -- IMPORTANT: only run if local player is ALIVE, otherwise we block respawn (white screen freeze)
    if Config.TrollTarget and Config.TrollTarget.Character and humanoid and humanoid.Health > 0 then
        local tRoot = Config.TrollTarget.Character:FindFirstChild("HumanoidRootPart")
        if tRoot and root then
            if Config.TrollMode == "Follow" then
                root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3)
            elseif Config.TrollMode == "Orbit" then
                local angle = tick() * Config.TrollSpeed
                root.CFrame = CFrame.new(tRoot.Position + Vector3.new(math.cos(angle) * 5, 0, math.sin(angle) * 5), tRoot.Position)
            elseif Config.TrollMode == "Stalk" then
                root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 4.5)
            elseif Config.TrollMode == "BasicFling" then
                -- Simple fling: ram into target with moderate velocity
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
                root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 0.3)
                root.AssemblyLinearVelocity = Vector3.new(
                    math.random(-300, 300), math.random(200, 500), math.random(-300, 300)
                )
            end
        end
    end
    
    -- 5. Auto Grab Gun (searches descendants — MM2 nests the dropped gun inside folders)
    if Config.AutoGrabGun and root then
        local gunDrop = nil
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("Tool") and (v.Name == "Gun" or v.Name == "GunDrop" or v.Name == "DroppedGun" or v.Name == "RealGun") then
                -- Only grab guns lying in workspace/map, not ones in player inventories
                if not v:FindFirstAncestorWhichIsA("Player") and not v:FindFirstAncestorWhichIsA("Backpack") then
                    gunDrop = v
                    break
                end
            end
        end
        if gunDrop then
            local handle = gunDrop:FindFirstChild("Handle")
            root.CFrame = handle and handle.CFrame or gunDrop:GetPivot()
        end
    end
    
    -- 6. Auto Collect Coins
    if Config.AutoCollectCoins and root and tick() - lastCoinCollect > 0.4 then
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and (v.Name == "Coin_Container" or v.Name == "Coin" or v.Parent.Name == "CoinContainer") then
                root.CFrame = v.CFrame
                lastCoinCollect = tick()
                break
            end
        end
    end
    
    -- 7. Auto Stab (Murderer Reach)
    if Config.AutoStab and char and char:FindFirstChild("Knife") then
        local knife = char:FindFirstChild("Knife")
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local pRoot = p.Character:FindFirstChild("HumanoidRootPart")
                local pHum = p.Character:FindFirstChildOfClass("Humanoid")
                if pRoot and pHum and pHum.Health > 0 then
                    local dist = (root.Position - pRoot.Position).Magnitude
                    if dist <= Config.StabReach then
                        knife:Activate()
                        local handle = knife:FindFirstChild("Handle")
                        if handle then
                            firetouchinterest(handle, pRoot, 0)
                            firetouchinterest(handle, pRoot, 1)
                        end
                    end
                end
            end
        end
    end
    
    -- 8. Visual Item ESP updates (throttled — every 2s to avoid lag)
    if tick() - lastItemESPUpdate > 2 then
        lastItemESPUpdate = tick()
        UpdateItemESP()
    end
end))


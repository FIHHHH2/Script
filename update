-- ╚══════════════════════════════════════════════════════════════╝
local function UpdateItemESP()
    -- If both item ESPs are off, wipe all BoxHandleAdornments and bail early
    if not Config.CoinESP and not Config.GunESP then
        for _, child in ipairs(EspFolder:GetChildren()) do
            if child:IsA("BoxHandleAdornment") then
                child:Destroy()
            end
        end
        return
    end
    
    -- Clean up coin boxes if CoinESP just got disabled
    if not Config.CoinESP then
        for _, child in ipairs(EspFolder:GetChildren()) do
            if child:IsA("BoxHandleAdornment") and child.Color3 == Color3.fromRGB(241, 196, 15) then
                child:Destroy()
            end
        end
    end
    
    -- Clean up gun boxes if GunESP just got disabled
    if not Config.GunESP then
        for _, child in ipairs(EspFolder:GetChildren()) do
            if child:IsA("BoxHandleAdornment") and child.Color3 == Color3.fromRGB(52, 152, 219) then
                child:Destroy()
            end
        end
    end
    
    for _, v in ipairs(workspace:GetDescendants()) do
        if Config.CoinESP and v:IsA("BasePart") and (v.Name == "Coin_Container" or v.Name == "Coin" or (v.Parent and v.Parent.Name == "CoinContainer")) then
            local esp = EspFolder:FindFirstChild(v:GetDebugId())
            if not esp then
                esp = Instance.new("BoxHandleAdornment")
                esp.Name = v:GetDebugId()
                esp.Adornee = v
                esp.AlwaysOnTop = true
                esp.ZIndex = 5
                esp.Size = v.Size
                esp.Color3 = Color3.fromRGB(241, 196, 15)
                esp.Transparency = 0.5
                esp.Parent = EspFolder
            end
        elseif Config.GunESP and v:IsA("BasePart") and v.Name == "GunDrop" then
            local esp = EspFolder:FindFirstChild(v:GetDebugId())
            if not esp then
                esp = Instance.new("BoxHandleAdornment")
                esp.Name = v:GetDebugId()
                esp.Adornee = v
                esp.AlwaysOnTop = true
                esp.ZIndex = 6
                esp.Size = v.Size
                esp.Color3 = Color3.fromRGB(52, 152, 219)
                esp.Transparency = 0.4
                esp.Parent = EspFolder
            end
        end
    end
end


-- ║              BYPASS METATABLE HOOKS (__newindex)             ║
-- ╚══════════════════════════════════════════════════════════════╝
local OldNamecall, OldIndex, OldNewIndex
local HooksInstalled = false

local function InstallHooks()
    if HooksInstalled then return end
    HooksInstalled = true
    
    pcall(function()
        local mt = getrawmetatable(game)
        OldNamecall = mt.__namecall
        OldIndex = mt.__index
        OldNewIndex = mt.__newindex
        
        setreadonly(mt, false)
        
        -- Bypass MM2 WalkSpeed/JumpPower overrides
        mt.__newindex = newcclosure(function(self, key, value)
            if not checkcaller() and self:IsA("Humanoid") and self.Parent == LocalPlayer.Character then
                if key == "WalkSpeed" and Config.WalkSpeedEnabled then
                    return OldNewIndex(self, key, Config.WalkSpeedValue)
                elseif key == "JumpPower" and Config.JumpPowerEnabled then
                    return OldNewIndex(self, key, Config.JumpPowerValue)
                end
            end
            return OldNewIndex(self, key, value)
        end)
        
        -- Silent Aim hooks
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if Config.SilentAimEnabled and CachedSilentTarget and (method == "FireServer" or method == "InvokeServer") then
                local args = {...}
                for i, arg in ipairs(args) do
                    if typeof(arg) == "Vector3" then
                        args[i] = CachedSilentTarget.Position
                    elseif typeof(arg) == "CFrame" then
                        args[i] = CFrame.new(CachedSilentTarget.Position)
                    end
                end
                return OldNamecall(self, unpack(args))
            end
            return OldNamecall(self, ...)
        end)
        
        mt.__index = newcclosure(function(self, key)
            if Config.SilentAimEnabled and CachedSilentTarget and not checkcaller() and self == Mouse then
                if key == "Hit" then return CFrame.new(CachedSilentTarget.Position) end
                if key == "Target" then return CachedSilentTarget end
            end
            return OldIndex(self, key)
        end)
        
        setreadonly(mt, true)
    end)
end

local function RemoveHooks()
    if not HooksInstalled then return end
    pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        mt.__namecall = OldNamecall
        mt.__index = OldIndex
        mt.__newindex = OldNewIndex
        setreadonly(mt, true)
    end)
    HooksInstalled = false
end

InstallHooks()

-- Re‑install hooks whenever the local character respawns (prevents the hook from losing its reference after a death/rejoin)

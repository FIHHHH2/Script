    valLabel.TextColor3 = Theme.AccentGlow
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    valLabel.Text = tostring(default)
    valLabel.Parent = container
    
    local trackFrame = Instance.new("Frame")
    trackFrame.Size = UDim2.new(1, -24, 0, 4)
    trackFrame.Position = UDim2.new(0, 12, 0, 32)
    trackFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    trackFrame.BorderSizePixel = 0
    trackFrame.Parent = container
    AddCorner(trackFrame, 2)
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    fill.BackgroundColor3 = Theme.Accent
    fill.BorderSizePixel = 0
    fill.Parent = trackFrame
    AddCorner(fill, 2)
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 10, 0, 10)
    knob.Position = UDim2.new((default-min)/(max-min), -5, 0.5, -5)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Parent = trackFrame
    AddCorner(knob, 5)
    
    local function UpdateVal(inputX)
        local pct = math.clamp((inputX - trackFrame.AbsolutePosition.X) / trackFrame.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + (max - min) * pct)
        valLabel.Text = tostring(val)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, -5, 0.5, -5)
        callback(val)
    end
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = trackFrame
    
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            ActiveSliderUpdate = UpdateVal
            UpdateVal(input.Position.X)
        end
    end)
    btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if ActiveSliderUpdate == UpdateVal then ActiveSliderUpdate = nil end
        end
    end)
end


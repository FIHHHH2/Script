local function GetPlayerRole(player)
    if not player then return "Civilian" end
    local char = player.Character
    local backpack = player:FindFirstChild("Backpack")
    
    local hasKnife = false
    local hasGun = false
    
    if char then
        if char:FindFirstChild("Knife") or char:FindFirstChild("RealKnife") then hasKnife = true end
        if char:FindFirstChild("Gun") or char:FindFirstChild("RealGun") then hasGun = true end
    end
    if backpack then
        if backpack:FindFirstChild("Knife") or backpack:FindFirstChild("RealKnife") then hasKnife = true end
        if backpack:FindFirstChild("Gun") or backpack:FindFirstChild("RealGun") then hasGun = true end
    end
    
    if hasKnife then return "Murderer" end
    if hasGun then
        -- If the original sheriff is dead and someone else has the gun, they're the Hero
        local isSheriff = true
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p ~= LocalPlayer then
                local pChar = p.Character
                local pHum = pChar and pChar:FindFirstChildOfClass("Humanoid")
                if pHum and pHum.Health <= 0 then
                    local pBp = p:FindFirstChild("Backpack")
                    -- Dead player who HAD a gun = original sheriff died, current holder is Hero
                    if (pChar and (pChar:FindFirstChild("Gun") or pChar:FindFirstChild("RealGun")))
                        or (pBp and (pBp:FindFirstChild("Gun") or pBp:FindFirstChild("RealGun"))) then
                        isSheriff = false
                    end
                end
            end
        end
        return isSheriff and "Sheriff" or "Hero"
    end
    return "Civilian"
end

local function GetRoleColor(role)
    if role == "Murderer" then return Color3.fromRGB(231, 76, 60) end   -- Red
    if role == "Sheriff"  then return Color3.fromRGB(52, 152, 219) end  -- Blue
    if role == "Hero"     then return Color3.fromRGB(46, 204, 113) end  -- Green
    return Color3.fromRGB(200, 200, 210)                                -- White/grey for Civilian
end

local function GetRoleIcon(role)
    if role == "Murderer" then return "🔪" end
    if role == "Sheriff"  then return "🔫" end
    if role == "Hero"     then return "🛡" end
    return "👤"
end


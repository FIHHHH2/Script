local function CreatePlayerESP(player)
    if player == LocalPlayer then return end
    
    local function UpdateESP()
        local char = player.Character
        local head = char and char:FindFirstChild("Head")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        
        local highlight = EspFolder:FindFirstChild(player.Name .. "_Highlight")
        local billboard = EspFolder:FindFirstChild(player.Name .. "_Billboard")
        
        if Config.ESPEnabled and head and humanoid and humanoid.Health > 0 then
            local role = GetPlayerRole(player)
            local color = GetRoleColor(role)
            local icon = GetRoleIcon(role)
            
            -- Outline highlight on the character
            if not highlight then
                highlight = Instance.new("Highlight")
                highlight.Name = player.Name .. "_Highlight"
                highlight.FillTransparency = 1        -- no fill, outline only
                highlight.OutlineTransparency = 0.1
                highlight.Parent = EspFolder
            end
            highlight.Adornee = char
            highlight.FillColor = color
            highlight.OutlineColor = color
            
            -- Billboard above head
            if not billboard then
                billboard = Instance.new("BillboardGui")
                billboard.Name = player.Name .. "_Billboard"
                billboard.AlwaysOnTop = true
                billboard.Size = UDim2.new(0, 160, 0, 40)
                billboard.StudsOffset = Vector3.new(0, 2.8, 0)
                billboard.Parent = EspFolder
                
                local roleLbl = Instance.new("TextLabel")
                roleLbl.Name = "RoleLabel"
                roleLbl.BackgroundTransparency = 1
                roleLbl.Size = UDim2.new(1, 0, 0.55, 0)
                roleLbl.Position = UDim2.new(0, 0, 0, 0)
                roleLbl.Font = Enum.Font.GothamBold
                roleLbl.TextSize = 14
                roleLbl.TextStrokeTransparency = 0
                roleLbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                roleLbl.Parent = billboard
                
                local infoLbl = Instance.new("TextLabel")
                infoLbl.Name = "InfoLabel"
                infoLbl.BackgroundTransparency = 1
                infoLbl.Size = UDim2.new(1, 0, 0.45, 0)
                infoLbl.Position = UDim2.new(0, 0, 0.55, 0)
                infoLbl.Font = Enum.Font.GothamMedium
                infoLbl.TextSize = 10
                infoLbl.TextStrokeTransparency = 0.3
                infoLbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                infoLbl.TextColor3 = Color3.fromRGB(180, 180, 190)
                infoLbl.Parent = billboard
            end
            billboard.Adornee = head
            
            local roleLbl = billboard:FindFirstChild("RoleLabel")
            local infoLbl = billboard:FindFirstChild("InfoLabel")
            if roleLbl then
                roleLbl.Text = icon .. " " .. role
                roleLbl.TextColor3 = color
            end
            if infoLbl then
                local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                local root = char:FindFirstChild("HumanoidRootPart")
                local dist = (myRoot and root) and math.floor((root.Position - myRoot.Position).Magnitude) or 0
                infoLbl.Text = player.Name .. " [" .. dist .. " studs]"
            end
        else
            if highlight then highlight:Destroy() end
            if billboard then billboard:Destroy() end
        end
    end
    
    local conn = RunService.RenderStepped:Connect(UpdateESP)
    track(conn)
    
    player.CharacterRemoving:Connect(function()
        local highlight = EspFolder:FindFirstChild(player.Name .. "_Highlight")
        local billboard = EspFolder:FindFirstChild(player.Name .. "_Billboard")
        if highlight then highlight:Destroy() end
        if billboard then billboard:Destroy() end
    end)
end

for _, p in ipairs(Players:GetPlayers()) do CreatePlayerESP(p) end

        FlingSpin.AngularVelocity = Vector3.new(0, 80, 0)
        FlingSpin.Parent = root
        
        FlingConnection = RunService.Heartbeat:Connect(function()
            local tChar = target.Character
            local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
            local tHum = tChar and tChar:FindFirstChildOfClass("Humanoid")
            
            if not target.Parent or not root.Parent or hum.Health <= 0 or not tRoot or not tHum or tHum.Health <= 0 then
                StopFling()
                return
            end
            
            -- Out-of-bounds safety check (void fall or launched too far away)
            local currentPos = root.Position
            local startPos = origCF and origCF.Position
            local horizontalDist = startPos and (Vector3.new(currentPos.X, 0, currentPos.Z) - Vector3.new(startPos.X, 0, startPos.Z)).Magnitude or 0
            
            if currentPos.Y < -80 or (startPos and currentPos.Y < startPos.Y - 45) or horizontalDist > 400 then
                StopFling()
                return
            end
            
            hum.Sit = true
            
            -- Keep CanCollide FALSE on limbs but TRUE on root so physics collisions
            -- actually transfer momentum to the target instead of phasing through
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part ~= root then
                    part.CanCollide = false
                end
            end
            root.CanCollide = true
            
            -- Teleport right inside target and apply velocity TOWARD them (not skyward)
            local dirToTarget = (tRoot.Position - root.Position).Unit
            root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 0)
            root.AssemblyLinearVelocity = dirToTarget * 300 + Vector3.new(0, 50, 0)
            root.AssemblyAngularVelocity = Vector3.new(0, 80, 0)
        end)
    end
    
    -- State-aware action buttons (only one active at a time)
    local flingBtn, basicFlingBtn, stalkBtn, orbitBtn
    
    local function ResetAllActionBtns()
        if flingBtn then
            flingBtn.Text = "💥 Advanced Fling"
            flingBtn.BackgroundColor3 = Theme.BtnFling
            _btnBaseColors[flingBtn] = Theme.BtnFling
        end
        if basicFlingBtn then
            basicFlingBtn.Text = "💫 Basic Fling"
            basicFlingBtn.BackgroundColor3 = Theme.BtnFling
            _btnBaseColors[basicFlingBtn] = Theme.BtnFling
        end
        if stalkBtn then
            stalkBtn.Text = "👁 Stalk Target"
            stalkBtn.BackgroundColor3 = Theme.BtnInfo
            _btnBaseColors[stalkBtn] = Theme.BtnInfo
        end
        if orbitBtn then
            orbitBtn.Text = "🌀 Orbit Target"
            orbitBtn.BackgroundColor3 = Theme.BtnInfo
            _btnBaseColors[orbitBtn] = Theme.BtnInfo
        end
    end
    
    CreateButton(page, "🔀 Teleport to Target", function()
        if Config.TrollTarget and Config.TrollTarget.Character then
            local tRoot = Config.TrollTarget.Character:FindFirstChild("HumanoidRootPart")
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if tRoot and myRoot then myRoot.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3) end
        end
    end, Theme.BtnMovement, Theme.BtnMovementHov)
    
    flingBtn = CreateButton(page, "💥 Advanced Fling", function()
        if Config.TrollTarget then
            if Config.TrollMode == "Fling" then
                StopFling()
                ResetAllActionBtns()
            else
                StopFling()
                ResetAllActionBtns()
                StartFling(Config.TrollTarget)
                flingBtn.Text = "💥 Advanced Fling [ON]"
                flingBtn.BackgroundColor3 = Theme.AccentGlow
                _btnBaseColors[flingBtn] = Theme.AccentGlow
            end
        end
    end, Theme.BtnFling, Theme.BtnFlingHov)
    
    basicFlingBtn = CreateButton(page, "💫 Basic Fling", function()
        if Config.TrollTarget then
            if Config.TrollMode == "BasicFling" then
                Config.TrollMode = "None"
                ResetAllActionBtns()
            else
                StopFling()
                ResetAllActionBtns()
                Config.TrollMode = "BasicFling"
                basicFlingBtn.Text = "💫 Basic Fling [ON]"
                basicFlingBtn.BackgroundColor3 = Theme.AccentGlow
                _btnBaseColors[basicFlingBtn] = Theme.AccentGlow
            end
        end
    end, Theme.BtnFling, Theme.BtnFlingHov)
    
    stalkBtn = CreateButton(page, "👁 Stalk Target", function()
        if Config.TrollTarget then
            local wasStalk = Config.TrollMode == "Stalk"
            StopFling()
            ResetAllActionBtns()
            if not wasStalk then
                Config.TrollMode = "Stalk"
                stalkBtn.Text = "👁 Stalk [ON]"
                stalkBtn.BackgroundColor3 = Theme.AccentGlow
                _btnBaseColors[stalkBtn] = Theme.AccentGlow
            end
        end
    end, Theme.BtnInfo, Theme.BtnInfoHov)
    
    orbitBtn = CreateButton(page, "🌀 Orbit Target", function()
        if Config.TrollTarget then
            local wasOrbit = Config.TrollMode == "Orbit"
            StopFling()
            ResetAllActionBtns()
            if not wasOrbit then
                Config.TrollMode = "Orbit"
                orbitBtn.Text = "🌀 Orbit [ON]"
                orbitBtn.BackgroundColor3 = Theme.AccentGlow
                _btnBaseColors[orbitBtn] = Theme.AccentGlow
            end
        end
    end, Theme.BtnInfo, Theme.BtnInfoHov)
    
    CreateHeader(page, "Target Combat & Spectate")
    
    CreateButton(page, "👀 Spectate Target", function()
        if Config.TrollTarget and Config.TrollTarget.Character then
            local hum = Config.TrollTarget.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                Camera.CameraSubject = hum
            end
        end
    end, Theme.BtnInfo, Theme.BtnInfoHov)
    
    CreateButton(page, "📹 Unspectate (Reset Cam)", function()
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            Camera.CameraSubject = hum
        end
    end, Theme.BtnMovement, Theme.BtnMovementHov)
    
    CreateButton(page, "🔪 Kill Target (Murderer)", function()
        if not Config.TrollTarget or not Config.TrollTarget.Character then return end
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local kn = char and (char:FindFirstChild("Knife") or (LocalPlayer.Backpack and LocalPlayer.Backpack:FindFirstChild("Knife")))
        if not (root and kn) then return end
        
        local tRoot = Config.TrollTarget.Character:FindFirstChild("HumanoidRootPart")
        if tRoot then
            local oldCF = root.CFrame
            if kn.Parent ~= char then kn.Parent = char task.wait(0.1) end
            root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 1.5)
            task.wait(0.08)
            kn:Activate()
            local handle = kn:FindFirstChild("Handle")
            if handle then
                firetouchinterest(handle, tRoot, 0)
                firetouchinterest(handle, tRoot, 1)
            end
            task.wait(0.1)
            root.CFrame = oldCF
        end
    end, Theme.BtnDanger, Theme.BtnDangerHov)
    
    CreateButton(page, "🔫 Shoot Target (Sheriff)", function()
        if not Config.TrollTarget or not Config.TrollTarget.Character then return end
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local gun = char and (char:FindFirstChild("Gun") or (LocalPlayer.Backpack and LocalPlayer.Backpack:FindFirstChild("Gun")))
        if not (root and gun) then return end
        
        local tRoot = Config.TrollTarget.Character:FindFirstChild("HumanoidRootPart")
        if tRoot then
            local oldCF = root.CFrame
            root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 4)
            task.wait(0.1)
            if gun.Parent ~= char then gun.Parent = char task.wait(0.1) end
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, tRoot.Position)
            gun:Activate()
            task.wait(0.2)
            root.CFrame = oldCF
        end
    end, Theme.BtnDanger, Theme.BtnDangerHov)
    
    -- Ensure clean teardown of fling loop in panic exit
    local originalCleanup = _G.MM2_Cleanup
    _G.MM2_Cleanup = function()
        StopFling()
        if originalCleanup then originalCleanup() end
    end
end

